# ══════════════════════════════════════════════════════════════════════════
# Avoqado Server - Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════
#
# 📋 Instructions:
#   1. Copy this file to .env for LOCAL DEVELOPMENT ONLY
#   2. Replace placeholder values with your actual credentials
#   3. NEVER commit .env files to version control
#
# 🚨 IMPORTANT - Where to set variables for each environment:
#   ┌─────────────┬──────────────────────────────────────────────────────┐
#   │ Environment │ Where to configure                                   │
#   ├─────────────┼──────────────────────────────────────────────────────┤
#   │ Local Dev   │ .env file (this template → copy to .env)            │
#   │ Staging     │ Render Dashboard → avoqado-server-staging → Env Vars│
#   │ Production  │ Render Dashboard → avoqado-server → Env Vars        │
#   │ Demo        │ fly secrets set KEY=value -a avoqado-server         │
#   │ CI/CD Tests │ GitHub → Settings → Secrets and variables           │
#   └─────────────┴──────────────────────────────────────────────────────┘
#
# 💡 Quick Start (minimum required for local dev):
#   - DATABASE_URL
#   - ACCESS_TOKEN_SECRET (or JWT_SECRET)
#   - SESSION_SECRET
#   - COOKIE_SECRET
#
# ══════════════════════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🗄️  DATABASE                                                             │
# └──────────────────────────────────────────────────────────────────────────┘

# PostgreSQL connection string
# Local: postgresql://USER:PASSWORD@localhost:5432/DB_NAME
# Neon: postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require
DATABASE_URL=postgresql://postgres:exitosoy777@localhost:5432/av-db-25

# Optional: Separate URL for running tests (recommended to avoid polluting dev DB)
# TEST_DATABASE_URL=postgresql://postgres:exitosoy777@localhost:5432/av-db-test


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔴 REDIS (Session Store & Rate Limiting)                                 │
# └──────────────────────────────────────────────────────────────────────────┘

# Local Redis (default): redis://localhost:6379
# Upstash Redis: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🐰 RABBITMQ (POS Command Queue - Optional)                               │
# └──────────────────────────────────────────────────────────────────────────┘

# CloudAMQP: amqps://USER:PASSWORD@HOST/VHOST
# Local: amqp://guest:guest@localhost:5672
RABBITMQ_URL=amqp://guest:guest@localhost:5672


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔐 AUTHENTICATION                                                        │
# └──────────────────────────────────────────────────────────────────────────┘

# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_change_this_in_production
SESSION_SECRET=your_session_secret_here_change_this_in_production
# OTP_PEPPER: required by env.ts (min 16 chars). Generate with: openssl rand -base64 32
OTP_PEPPER=your_otp_pepper_here_min_16_chars_change_this


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🧠 OPENAI (Text-to-SQL Chatbot)                                          │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 💳 STRIPE (Subscriptions & Feature Access)                               │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret (run: stripe listen --forward-to localhost:3000/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 💰 BLUMON PAYMENT SDK (E-commerce Checkout)                              │
# └──────────────────────────────────────────────────────────────────────────┘

# Set to 'true' to use mock service (unlimited testing, no API calls)
# Set to 'false' to use real Blumon sandbox API
# 💡 Recommended: Keep as 'true' during development
USE_BLUMON_MOCK=true

# Master merchant credentials (for OAuth authentication)
# Get from: Blumon sales team (Edgardo)
BLUMON_MASTER_USERNAME=your_blumon_master_email@example.com
BLUMON_MASTER_PASSWORD=your_blumon_master_password_here

# KYC document delivery emails (comma-separated)
# When superadmin approves KYC, documents are automatically sent to these emails
# Production: afiliaciones@blumonpay.com,comercial@blumonpay.com,soporte@blumonpay.com,hola@avoqado.io
BLUMON_KYC_EMAILS=your-test-email@example.com,another-test@example.com


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 📧 EMAIL SERVICE (Resend)                                                │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email from address (must be verified in Resend)
EMAIL_FROM=noreply@avoqado.io

# Email address to receive terminal purchase order notifications
ORDER_NOTIFICATIONS_EMAIL=orders@avoqado.io


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔥 FIREBASE (Push Notifications - Optional)                              │
# └──────────────────────────────────────────────────────────────────────────┘

# Path to Firebase service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔍 GOOGLE OAUTH & BUSINESS PROFILE (Optional)                            │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/dashboard/google/callback

# For Google Business Profile API
GOOGLE_API_KEY=your_google_api_key_here

# Consumer app OAuth audiences (comma-separated client IDs / bundle IDs)
# Google: iOS, Android, and Expo/web client IDs accepted by Avoqado consumer app
CONSUMER_GOOGLE_CLIENT_IDS=
CONSUMER_APP_RETURN_URL=avoqado://payment-result
# Apple: Services ID / bundle ID values expected in Apple identityToken `aud`
CONSUMER_APPLE_AUDIENCES=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🛠️  APPLICATION SETTINGS                                                 │
# └──────────────────────────────────────────────────────────────────────────┘

# Environment: development | production | staging
NODE_ENV=development

# Server port
PORT=3000

# Base URL (for OAuth callbacks, webhooks, etc.)
BASE_URL=http://localhost:3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable simple console logging (no JSON, useful for local dev)
# SIMPLE_LOGGING=true

# Enable development tools (webhook simulator, session dashboard, etc.)
ENABLE_DEV_TOOLS=true


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 📊 ANALYTICS & MONITORING (Optional)                                     │
# └──────────────────────────────────────────────────────────────────────────┘

# Sentry for error tracking
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/123456

# PostHog for product analytics
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://app.posthog.com


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🧪 TESTING                                                               │
# └──────────────────────────────────────────────────────────────────────────┘

# Use in-memory database for tests (faster, but requires cleanup)
# TEST_DATABASE_URL=postgresql://postgres:exitosoy777@localhost:5432/av-db-test


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🚀 DEPLOYMENT (Production Only)                                          │
# └──────────────────────────────────────────────────────────────────────────┘

# These are set automatically by hosting providers (Fly.io, Render, etc.)
# Don't set these locally

# FLY_APP_NAME=avoqado-server
# FLY_REGION=mia
# RENDER_INSTANCE_ID=
# RENDER_SERVICE_NAME=


# ══════════════════════════════════════════════════════════════════════════
# 💡 TIPS
# ══════════════════════════════════════════════════════════════════════════
#
# 1. Test your .env file with: npm run dev
#
# 2. Validate database connection: npx prisma db pull
#
# 3. Run migrations: npm run migrate
#
# 4. Seed database: npm run seed
#
# 5. Check Blumon setup: npm run blumon:help
#
# ══════════════════════════════════════════════════════════════════════════

# ── GOOGLE CALENDAR SYNC (Phase 1) ────────────────────────────────────────
# OAuth credentials from https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" (type: Web application) and add the redirect
# URI below to its authorized redirect list before the dashboard can connect.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.avoqado.io/api/v1/google-calendar/oauth/callback
# 32-byte hex (64 chars) AES-256-GCM key for encrypting refresh tokens at rest.
# Generate with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
# ROTATE-SEPARATELY from JWT_SECRET — leaking this key exposes every connected
# Google account. Rotation procedure: see docs/PRODUCTION_READINESS_CHECKLIST.md.
GOOGLE_CALENDAR_TOKEN_KEY=
# Public base URL Google posts watch-notifications to. Must be HTTPS.
GOOGLE_CALENDAR_WEBHOOK_BASE=https://api.avoqado.io
# HMAC secret for the OAuth `state` JWT (CSRF + intent envelope). Separate from
# JWT_SECRET so we can rotate without invalidating user sessions.
OAUTH_STATE_SECRET=
# Frontend origin we redirect back to after OAuth callback (default URL of
# the dashboard, used to construct the success/failure redirect target).
DASHBOARD_URL=https://dashboardv2.avoqado.io

# ============================================================================
# Mercado Pago — Marketplace (Split Payments via Checkout Bricks)
# ============================================================================
# OAuth credentials. CLIENT_ID = "Número de aplicación" from MP DevPanel.
# CLIENT_SECRET lives in the app Configuración section (not the test panel).
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# Avoqado's OWN test public key + access token from MP DevPanel → Credenciales
# de prueba. NOT a seller's. Sellers' tokens land in EcommerceMerchant
# .providerCredentials (encrypted with MERCADO_PAGO_TOKEN_KEY below).
MP_PUBLIC_KEY_TEST=
MP_ACCESS_TOKEN_TEST=
# Where MP redirects after seller authorization. Must match the URI
# registered in the MP DevPanel. Use an ngrok HTTPS URL during local dev.
MP_REDIRECT_URI=
# HMAC secret MP uses to sign IPN webhook deliveries. Get it from MP DevPanel
# → Notificaciones → Webhooks (returned on save).
MP_WEBHOOK_SECRET=
# 32-byte hex (64 chars) AES-256-GCM key encrypting MP seller refresh+access
# tokens at rest. ROTATE SEPARATELY from JWT_SECRET and GOOGLE_CALENDAR_TOKEN_KEY.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MERCADO_PAGO_TOKEN_KEY=
# MP API hosts. Defaults shown; override only for tests or regional variations.
MP_API_BASE_URL=https://api.mercadopago.com
MP_AUTH_BASE_URL=https://auth.mercadopago.com.mx

# ============================================================================
# 🛒 TPV SHOP — Plans 1+2+3
# ============================================================================

# SPEI recipient (datos bancarios donde el venue manda la transferencia)
SPEI_RECIPIENT_BENEFICIARY="SERVICIOS TECNOLOGICOS AVO SA DE CV"
SPEI_RECIPIENT_CLABE=699180600007741022
SPEI_RECIPIENT_RFC=STA241210PW8
SPEI_RECIPIENT_BANK=STP

# Magic-link JWT secret. Genera con: openssl rand -hex 32
# 7 días default para approve/reject, 30 días para assign-serials.
TERMINAL_ORDER_TOKEN_SECRET=<32+ chars random hex>

# Superadmin app URL — base de los magic links en correos a sales.
#   Dev local:  http://localhost:5177
#   Staging:    https://staging.superadmin.avoqado.io
#   Prod:       https://superadmin.avoqado.io
SUPERADMIN_URL=http://localhost:5177

# When 'true', exposes the optional MP/Stripe Connect step at the end of the
# V2 setup wizard (Step 8). Spec:
#   docs/superpowers/specs/2026-05-27-onboarding-payment-providers-design.md
# Frontend reads `VITE_ENABLE_ONBOARDING_PAYMENT_PROVIDERS` separately.
ENABLE_ONBOARDING_PAYMENT_PROVIDERS=true

# When 'true', exposes the optional "Buy TPV" step at the end of the V2 setup
# wizard (Step 9, after payment providers). The progress endpoint then includes
# `tpvPurchase: { tpvOrderId, skipped }` so the wizard can hydrate View B
# (existing order) on return from Stripe Checkout or after a tab close. Spec:
#   docs/superpowers/specs/2026-05-29-onboarding-tpv-purchase-design.md
# Frontend reads `VITE_ENABLE_ONBOARDING_TPV_PURCHASE` separately.
ENABLE_ONBOARDING_TPV_PURCHASE=true

# When 'true', adds the mandatory Pro-plan step at the end of the V2 setup
# wizard (30-day trial / pay-now), creates the PLAN_PRO subscription on
# completion, gates the plan-setup-intent route, and enables the base-plan
# blanket feature grant (active plan/trial → all premium; non-payment → basic).
# Ops prereqs before prod: enable Stripe Tax + run scripts/seed-plan-pro.ts.
# Spec: docs/superpowers/specs/2026-06-02-venue-base-subscription-design.md
ENABLE_VENUE_BASE_SUBSCRIPTION=true

# Facturación CFDI (facturapi) — optional; required only for venues on the Pro plan that enable facturación
FACTURAPI_USER_KEY=        # sk_user_... (prod: provisions emisor organizations)
FACTURAPI_TEST_KEY=        # sk_test_... (dev/staging: non-billed sandbox stamping)
# FACTURAPI_BASE_URL=      # optional override
FISCAL_PROVIDER_KEY=       # 32-byte hex (openssl rand -hex 32) — encrypts per-emisor keys at rest

# ══════════════════════════════════════════════════════════════════════════
# Avoqado Server - Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════
#
# 📋 Instructions:
#   1. Copy this file to .env for LOCAL DEVELOPMENT ONLY
#   2. Replace placeholder values with your actual credentials
#   3. NEVER commit .env files to version control
#
# 🚨 IMPORTANT - Where to set variables for each environment:
#   ┌─────────────┬──────────────────────────────────────────────────────┐
#   │ Environment │ Where to configure                                   │
#   ├─────────────┼──────────────────────────────────────────────────────┤
#   │ Local Dev   │ .env file (this template → copy to .env)            │
#   │ Staging     │ Render Dashboard → avoqado-server-staging → Env Vars│
#   │ Production  │ Render Dashboard → avoqado-server → Env Vars        │
#   │ Demo        │ fly secrets set KEY=value -a avoqado-server         │
#   │ CI/CD Tests │ GitHub → Settings → Secrets and variables           │
#   └─────────────┴──────────────────────────────────────────────────────┘
#
# 💡 Quick Start (minimum required for local dev):
#   - DATABASE_URL
#   - ACCESS_TOKEN_SECRET (or JWT_SECRET)
#   - SESSION_SECRET
#   - COOKIE_SECRET
#
# ══════════════════════════════════════════════════════════════════════════

# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🗄️  DATABASE                                                             │
# └──────────────────────────────────────────────────────────────────────────┘

# PostgreSQL connection string
# Local: postgresql://USER:PASSWORD@localhost:5432/DB_NAME
# Neon: postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require
DATABASE_URL=postgresql://postgres:exitosoy777@localhost:5432/av-db-25

# Optional: Separate URL for running tests (recommended to avoid polluting dev DB)
# TEST_DATABASE_URL=postgresql://postgres:exitosoy777@localhost:5432/av-db-test


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔴 REDIS (Session Store & Rate Limiting)                                 │
# └──────────────────────────────────────────────────────────────────────────┘

# Local Redis (default): redis://localhost:6379
# Upstash Redis: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🐰 RABBITMQ (POS Command Queue - Optional)                               │
# └──────────────────────────────────────────────────────────────────────────┘

# CloudAMQP: amqps://USER:PASSWORD@HOST/VHOST
# Local: amqp://guest:guest@localhost:5672
RABBITMQ_URL=amqp://guest:guest@localhost:5672


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔐 AUTHENTICATION                                                        │
# └──────────────────────────────────────────────────────────────────────────┘

# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_change_this_in_production
SESSION_SECRET=your_session_secret_here_change_this_in_production


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🧠 OPENAI (Text-to-SQL Chatbot)                                          │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 💳 STRIPE (Subscriptions & Feature Access)                               │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret (run: stripe listen --forward-to localhost:3000/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 💰 BLUMON PAYMENT SDK (E-commerce Checkout)                              │
# └──────────────────────────────────────────────────────────────────────────┘

# Set to 'true' to use mock service (unlimited testing, no API calls)
# Set to 'false' to use real Blumon sandbox API
# 💡 Recommended: Keep as 'true' during development
USE_BLUMON_MOCK=true

# Master merchant credentials (for OAuth authentication)
# Get from: Blumon sales team (Edgardo)
BLUMON_MASTER_USERNAME=your_blumon_master_email@example.com
BLUMON_MASTER_PASSWORD=your_blumon_master_password_here

# KYC document delivery emails (comma-separated)
# When superadmin approves KYC, documents are automatically sent to these emails
# Production: afiliaciones@blumonpay.com,comercial@blumonpay.com,soporte@blumonpay.com,hola@avoqado.io
BLUMON_KYC_EMAILS=your-test-email@example.com,another-test@example.com


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 📧 EMAIL SERVICE (Resend)                                                │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email from address (must be verified in Resend)
EMAIL_FROM=noreply@avoqado.io

# Email address to receive terminal purchase order notifications
ORDER_NOTIFICATIONS_EMAIL=orders@avoqado.io


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔥 FIREBASE (Push Notifications - Optional)                              │
# └──────────────────────────────────────────────────────────────────────────┘

# Path to Firebase service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🔍 GOOGLE OAUTH & BUSINESS PROFILE (Optional)                            │
# └──────────────────────────────────────────────────────────────────────────┘

# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/dashboard/google/callback

# For Google Business Profile API
GOOGLE_API_KEY=your_google_api_key_here

# Consumer app OAuth audiences (comma-separated client IDs / bundle IDs)
# Google: iOS, Android, and Expo/web client IDs accepted by Avoqado consumer app
CONSUMER_GOOGLE_CLIENT_IDS=
# Apple: Services ID / bundle ID values expected in Apple identityToken `aud`
CONSUMER_APPLE_AUDIENCES=


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🛠️  APPLICATION SETTINGS                                                 │
# └──────────────────────────────────────────────────────────────────────────┘

# Environment: development | production | staging
NODE_ENV=development

# Server port
PORT=3000

# Base URL (for OAuth callbacks, webhooks, etc.)
BASE_URL=http://localhost:3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Enable simple console logging (no JSON, useful for local dev)
# SIMPLE_LOGGING=true

# Enable development tools (webhook simulator, session dashboard, etc.)
ENABLE_DEV_TOOLS=true


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 📊 ANALYTICS & MONITORING (Optional)                                     │
# └──────────────────────────────────────────────────────────────────────────┘

# Sentry for error tracking
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/123456

# PostHog for product analytics
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://app.posthog.com


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🧪 TESTING                                                               │
# └──────────────────────────────────────────────────────────────────────────┘

# Use in-memory database for tests (faster, but requires cleanup)
# TEST_DATABASE_URL=postgresql://postgres:exitosoy777@localhost:5432/av-db-test


# ┌──────────────────────────────────────────────────────────────────────────┐
# │ 🚀 DEPLOYMENT (Production Only)                                          │
# └──────────────────────────────────────────────────────────────────────────┘

# These are set automatically by hosting providers (Fly.io, Render, etc.)
# Don't set these locally

# FLY_APP_NAME=avoqado-server
# FLY_REGION=mia
# RENDER_INSTANCE_ID=
# RENDER_SERVICE_NAME=


# ══════════════════════════════════════════════════════════════════════════
# 💡 TIPS
# ══════════════════════════════════════════════════════════════════════════
#
# 1. Test your .env file with: npm run dev
#
# 2. Validate database connection: npx prisma db pull
#
# 3. Run migrations: npm run migrate
#
# 4. Seed database: npm run seed
#
# 5. Check Blumon setup: npm run blumon:help
#
# ══════════════════════════════════════════════════════════════════════════

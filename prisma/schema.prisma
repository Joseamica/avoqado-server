model KdsOrderItem {
  id          String   @id @default(cuid())
  kdsOrderId  String
  kdsOrder    KdsOrder @relation(fields: [kdsOrderId], references: [id], onDelete: Cascade)
  productName String
  quantity    Int
  modifiers   String? // JSON array of modifier names
  notes       String?

  @@index([kdsOrderId])
}

enum KdsOrderStatus {
  NEW
  PREPARING
  READY
  COMPLETED
}

// ============================================================================
// STAFF ONBOARDING STATE
// ============================================================================
// Per-staff, per-venue key/value store for onboarding UX state:
// - Tour banner dismissals (key: "tour-banner::<banner-id>")
// - Checklist progress        (key: "inventory-checklist", etc)
// - Welcome tour auto-launch  (key: "inventory-welcome-auto-launched")
// Replaces localStorage so progress persists across devices and can be analyzed.
// ============================================================================

model StaffOnboardingState {
  id      String @id @default(cuid())
  staffId String
  venueId String
  key     String // e.g. "inventory-checklist", "tour-banner::inventory-welcome"
  state   Json // Arbitrary JSON payload (booleans, step maps, timestamps)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([staffId, venueId, key])
  @@index([staffId, venueId])
}

// ============================================================================
// MERCADO PAGO — Webhook event dedupe
// ============================================================================

/// Dedupe table for Mercado Pago IPN webhooks.
///
/// MP sends duplicate deliveries for the same event (retry storms, multiple
/// notification triggers). The unique constraint on (mpUserId, dataId, requestId)
/// guarantees we only process each event once — the insert is the atomic
/// check (P2002 unique violation = duplicate, skip).
///
/// Also serves as an audit log: full raw payload kept for forensics,
/// processingStatus shows what we did with each event.
model MercadoPagoWebhookEvent {
  id String @id @default(cuid())

  /// MP seller user_id who owns the resource that triggered the event.
  /// Used to lookup the EcommerceMerchant via providerMerchantId.
  mpUserId String

  /// data.id from the IPN payload (payment id, merchant_order id, etc.).
  /// Lowercased to match the canonical form MP uses in the signature manifest.
  dataId String

  /// x-request-id header from MP. Together with mpUserId + dataId guarantees
  /// uniqueness; MP guarantees a fresh request-id per delivery attempt.
  requestId String

  /// IPN payload `type` (typically "payment", "merchant_order", "claim").
  eventType String

  /// IPN `action` (e.g. "payment.created", "payment.updated").
  action String

  /// Full raw payload, kept for forensics + replay testing.
  payload Json

  /// Outcome of our processing: "pending" (mid-flight), "processed",
  /// "ignored" (e.g. unsupported event type), "error".
  processingStatus String

  /// Optional error message if processing failed.
  errorMessage String?

  createdAt DateTime @default(now())

  @@unique([mpUserId, dataId, requestId])
  @@index([dataId])
  @@index([createdAt])
}

enum ReferralStatus {
  PENDING // Capturado en TPV/dashboard, Order aún no se cobra
  QUALIFIED // Order PAID, referidor recibió crédito
  VOID // Refund, fraude o anulado manualmente
}

enum ReferralTier {
  TIER_1
  TIER_2
  TIER_3
}

/// Dynamically-registered OAuth client (RFC 7591 DCR) for the customer-facing MCP.
model McpOAuthClient {
  clientId                String   @id
  clientSecretHash        String? // sha256 of the issued secret; null for public (PKCE) clients
  clientName              String?
  redirectUris            String[]
  grantTypes              String[] @default([])
  scope                   String?
  tokenEndpointAuthMethod String?  @default("none")
  clientIdIssuedAt        Int? // epoch seconds
  clientSecretExpiresAt   Int? // epoch seconds; 0 = never
  createdAt               DateTime @default(now())

  @@map("mcp_oauth_clients")
}

/// Single-use, short-lived authorization code (PKCE) for the customer MCP. Stored hashed.
model McpAuthCode {
  codeHash      String    @id // sha256(code)
  clientId      String
  staffId       String
  activeOrg     String
  codeChallenge String
  redirectUri   String
  scopes        String[]  @default([])
  resource      String?
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([expiresAt])
  @@map("mcp_auth_codes")
}

/// Refresh token (hashed at rest) for the customer MCP. Access tokens are stateless JWTs, not stored.
model McpRefreshToken {
  tokenHash String    @id // sha256(token)
  clientId  String
  staffId   String
  activeOrg String
  scopes    String[]  @default([])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([staffId])
  @@index([expiresAt])
  @@map("mcp_refresh_tokens")
}

// ─── Facturación CFDI 4.0 ───────────────────────────────────────────────
enum CsdStatus {
  NONE
  UPLOADED
  ACTIVE
  EXPIRED
  RESTRICTED
}

enum GlobalPeriodicity {
  DIARIO
  SEMANAL
  QUINCENAL
  MENSUAL
  BIMESTRAL
}

enum FiscalProviderType {
  FACTURAPI
  FACTURAMA
  ALEGRA
}

enum CfdiType {
  INGRESO
  EGRESO
  PAGO
}

enum CfdiStatus {
  DRAFT
  VALIDATING
  VALIDATION_FAILED
  STAMPING
  STAMPED
  STAMP_FAILED
  CANCEL_REQUESTED
  CANCELLED
}

enum CfdiFlow {
  STAFF_B
  AUTOFACTURA_A
  GLOBAL_C
}

enum CfdiCancelStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELLED
}

enum FiscalValidationStatus {
  UNVALIDATED
  VALID
  INVALID
}

/// The fiscal issuer (emisor) = one RFC + its CSD + provider binding. 1+ per venue.
model FiscalEmisor {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Legal identity (must match SAT)
  rfc             String
  legalName       String
  regimenFiscal   String // c_RegimenFiscal
  lugarExpedicion String // fiscal CP

  // Provider binding (provider-agnostic; facturapi = first adapter)
  provider         FiscalProviderType @default(FACTURAPI)
  providerOrgId    String? // facturapi org id / Alegra empresa id
  providerKeyEnc   String? // encrypted per-emisor key
  csdStatus        CsdStatus          @default(NONE)
  csdExpiresAt     DateTime?
  csdLastCheckedAt DateTime?

  // Comprobante defaults
  serie             String?
  defaultUsoCfdi    String            @default("G03")
  globalPeriodicity GlobalPeriodicity @default(MENSUAL)

  merchantConfigs MerchantFiscalConfig[]
  cfdis           Cfdi[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([venueId, rfc])
  @@index([venueId])
}

/// Per-merchant facturación enablement. Exactly ONE of the two merchant FKs is set.
/// Drives BOTH "which merchants invoice" (venue choice) and the customer-facing "facturar" gate.
model MerchantFiscalConfig {
  id String @id @default(cuid())

  merchantAccountId   String?            @unique // in-person POS merchant
  merchantAccount     MerchantAccount?   @relation(fields: [merchantAccountId], references: [id], onDelete: Cascade)
  ecommerceMerchantId String?            @unique // online channel merchant
  ecommerceMerchant   EcommerceMerchant? @relation(fields: [ecommerceMerchantId], references: [id], onDelete: Cascade)

  fiscalEmisorId String
  fiscalEmisor   FiscalEmisor @relation(fields: [fiscalEmisorId], references: [id], onDelete: Restrict)

  facturacionEnabled Boolean @default(false) // master switch for this merchant
  autofacturaEnabled Boolean @default(false) // customer self-invoice (Flow A) allowed
  includeInGlobal    Boolean @default(true) // included in month-end global sweep (Flow C)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fiscalEmisorId])
}

/// An issued (or in-flight) CFDI 4.0 fiscal document. NOTE: distinct from `Invoice` (internal SaaS billing).
model Cfdi {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Restrict)

  fiscalEmisorId String
  fiscalEmisor   FiscalEmisor @relation(fields: [fiscalEmisorId], references: [id], onDelete: Restrict)

  type   CfdiType   @default(INGRESO)
  status CfdiStatus @default(DRAFT)
  flow   CfdiFlow

  // Source (individual) OR global period
  orderId      String?
  order        Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  isGlobal     Boolean @default(false)
  globalPeriod Json? // { periodicidad, meses, anio }

  // Receptor snapshot (denormalized at issuance)
  receptorRfc     String
  receptorNombre  String
  receptorRegimen String
  receptorCp      String
  usoCfdi         String

  // SAT payment classification
  formaPago  String // c_FormaPago code
  metodoPago String // PUE / PPD

  // Money — integer cents (cuadra al centavo)
  subtotalCents Int
  discountCents Int   @default(0)
  taxCents      Int
  totalCents    Int
  taxBreakdown  Json? // [{ impuesto:002, tipo:Traslado, base, tasa, importe }, ...]

  // Provider + fiscal identifiers
  facturapiId String?
  uuid        String?   @unique // folio fiscal (timbre)
  serie       String?
  folio       String?
  stampedAt   DateTime?

  // Artifacts (blob storage URLs)
  xmlUrl   String?
  pdfUrl   String?
  acuseUrl String?

  // Errors / retries
  lastError      String? @db.Text
  attempts       Int     @default(0)
  idempotencyKey String? @unique

  // Cancellation (4.0)
  cancelMotivo         String? // 01/02/03/04
  cancelSubstituteUuid String? // required for motivo 01
  cancelStatus         CfdiCancelStatus?
  cancelRequestedAt    DateTime?
  cancelledAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, status])
  @@index([fiscalEmisorId, isGlobal, createdAt])
}

/// Receptor fiscal data. A Customer may have several; guests/autofactura create a one-off.
/// The receptor data is ALSO snapshotted onto the Cfdi at issuance.
model CustomerTaxProfile {
  id         String    @id @default(cuid())
  venueId    String
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  rfc            String
  razonSocial    String
  regimenFiscal  String
  codigoPostal   String
  defaultUsoCfdi String  @default("G03")
  email          String?

  validationStatus FiscalValidationStatus @default(UNVALIDATED)
  validatedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, rfc])
}

// ============================================
// CONCILIACIÓN BANCARIA (Bank Reconciliation con IA) — Feature PRO
// Slice 1: subir estado de cuenta (CSV) → conciliar vs depósitos esperados
// (pagos electrónicos netos por día). Ver bankReconciliation.service.ts.
// ============================================

model BankStatement {
  id           String              @id @default(cuid())
  venueId      String
  venue        Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  storagePath  String
  source       BankStatementSource @default(CSV)
  status       BankStatementStatus @default(PARSED)
  periodStart  DateTime?
  periodEnd    DateTime?
  lineCount    Int                 @default(0)
  matchedCount Int                 @default(0)
  uploadedById String? // Staff id (sin relación; el quién queda en ActivityLog)
  createdAt    DateTime            @default(now())
  lines        BankStatementLine[]

  @@index([venueId])
  @@index([venueId, createdAt])
}

model BankStatementLine {
  id              String            @id @default(cuid())
  bankStatementId String
  bankStatement   BankStatement     @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  venueId         String // denormalizado para aislamiento por tenant en queries directas
  rowIndex        Int
  postedDate      DateTime
  description     String
  reference       String?
  amountCents     Int // con signo; depósitos (CREDIT) > 0
  direction       BankLineDirection @default(CREDIT)
  matchStatus     ReconMatchStatus  @default(UNMATCHED)
  matchScore      Decimal?          @db.Decimal(4, 3)
  matchedKey      String? // día-candidato conciliado (YYYY-MM-DD), o null
  confirmedById   String?
  confirmedAt     DateTime?
  createdAt       DateTime          @default(now())

  @@index([venueId])
  @@index([bankStatementId])
  @@index([venueId, matchStatus])
}

enum BankStatementSource {
  CSV
  PDF
}

enum BankStatementStatus {
  PARSED
  RECONCILED
  FAILED
}

enum BankLineDirection {
  CREDIT
  DEBIT
}

enum ReconMatchStatus {
  UNMATCHED
  MATCHED
  DUPLICATE
  CONFIRMED
}

// ============================================
// CONTABILIDAD FISCAL (Capa B) — Catálogo de cuentas
// Scope = (organizationId, rfc) = el CONTRIBUYENTE, NO por venue (una org puede tener
// varios RFCs vía FiscalEmisor; cada RFC lleva su propio catálogo). Códigos del catálogo
// agrupador del SAT (c_CuentasSAT / Anexo 24). Es la ESTRUCTURA, sin saldos (los saldos
// se computan de JournalEntryLine cuando llegue el ledger). Gated PREMIUM (bundle con CFDI).
// Ver chartOfAccounts.service.ts + chartOfAccounts.catalog.ts (catálogo base verificado).
// ============================================

model LedgerAccount {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rfc             String // contribuyente (junto con organizationId); UPPERCASE-normalizado en el servicio
  code            String // NumCta (Anexo 24), formato SAT (p.ej. "102.01"); clave de negocio dentro de (org, rfc)
  satGroupingCode String // código agrupador del SAT (c_CuentasSAT); muchas cuentas comparten uno (no único)
  name            String // Descripción de la cuenta (Anexo 24)
  type            LedgerAccountType
  nature          LedgerAccountNature // 'D'/'A' en el XML; se mapea enum→letra en el serializador
  parentId        String? // SubCtaDe (FK self-relación). NULL solo en cuentas de mayor (nivel 1)
  parent          LedgerAccount?      @relation("LedgerAccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children        LedgerAccount[]     @relation("LedgerAccountHierarchy")
  accountMappings AccountMapping[] // configuración contable: movimientos que postean a esta cuenta
  journalLines    JournalLine[] // pólizas: líneas (cargo/abono) que afectan esta cuenta
  level           Int                 @default(1) // DENORMALIZADO: derivado de parentId (1 = mayor). Recalcular en la misma tx
  isPostable      Boolean             @default(true) // TRUE solo en hojas; una acumulativa (con hijos) DEBE ser false
  isActive        Boolean             @default(true) // soft-delete: cuentas con pólizas nunca se borran (inmutabilidad fiscal)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([organizationId, rfc, code]) // clave de negocio = base de la idempotencia del seed
  @@index([organizationId, rfc, parentId]) // recorridos del árbol / hijos de un nodo
  @@index([organizationId, rfc, satGroupingCode]) // rollup por código agrupador (balanza / catálogo XML)
  @@index([organizationId, rfc, isPostable]) // pickers de pólizas: solo hojas afectables
}

enum LedgerAccountType {
  ACTIVO
  PASIVO
  CAPITAL
  INGRESO
  COSTO
  GASTO
  ORDEN
}

enum LedgerAccountNature {
  DEUDORA
  ACREEDORA
}

// ============================================
// CONFIGURACIÓN CONTABLE — AccountMapping (Capa B)
// Mapa "tipo de movimiento → cuenta del catálogo" por (org, RFC). Hace que el motor de
// pólizas "dicte" los asientos sin que un humano escoja cuenta cada vez. Defaults por giro
// verificados (chartOfAccounts/accountMapping.catalog.ts), editables por el contador.
// Gated PREMIUM (bundle con CFDI). Ver accountMapping.service.ts.
// ============================================

model AccountMapping {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rfc             String // contribuyente (junto con organizationId)
  movementType    AccountMovementType // qué evento contable (SALES_REVENUE, COST_OF_GOODS_SOLD, …)
  ledgerAccountId String? // la cuenta a la que postea ese movimiento (null = aún sin asignar)
  ledgerAccount   LedgerAccount?      @relation(fields: [ledgerAccountId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([organizationId, rfc, movementType]) // un mapeo por movimiento por contribuyente (idempotencia del seed)
  @@index([organizationId, rfc])
}

enum AccountMovementType {
  SALES_REVENUE
  SALES_RETURN
  IVA_OUTPUT
  CASH_RECEIPT
  BANK_RECEIPT
  PETTY_CASH
  TIPS_PAYABLE
  ACCOUNTS_RECEIVABLE
  ACCOUNTS_PAYABLE
  INVENTORY
  INVENTORY_ADJUSTMENT
  COST_OF_GOODS_SOLD
  PROCESSOR_FEE
  ROUNDING_DIFFERENCE
  NET_INCOME_PROFIT
  NET_INCOME_LOSS
  RETAINED_EARNINGS
  IVA_INPUT
  IVA_INPUT_PENDING
  IVA_WITHHELD
  ISR_WITHHELD
  EXPENSE_GENERAL
  EXPENSE_RENT
  EXPENSE_FUEL
  PAYROLL_SALARIES
  ISR_PAYROLL_WITHHELD
  IMSS_PAYABLE
  SALARIES_PAYABLE
}

// ============================================
// LIBRO DIARIO · PÓLIZAS — motor de doble partida (Capa B)
// Cada póliza (JournalEntry) es un asiento BALANCEADO: Σdebe == Σhaber (invariante duro,
// validado al postear). Money en CENTAVOS enteros, MXN. Posteo idempotente por idempotencyKey.
// Scope (org, RFC) = contribuyente; venueId = centro de costos (informativo). Gated PREMIUM (CFDI).
// Ver journalEntry.service.ts.
// ============================================

model JournalEntry {
  id               String             @id @default(cuid())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rfc              String // contribuyente (junto con organizationId)
  venueId          String? // centro de costos (informativo; de qué local salió)
  date             DateTime // fecha del asiento (devengo/flujo)
  period           String // YYYY-MM, derivado de date (para balanza/cierre)
  folio            Int // consecutivo por (org, rfc)
  type             JournalEntryType   @default(DIARIO) // INGRESO / EGRESO / DIARIO (tipo de póliza SAT)
  source           JournalEntrySource @default(MANUAL) // MANUAL o el evento que la generó
  sourceId         String? // id del evento origen (Payment, Cfdi, …) para trazabilidad
  idempotencyKey   String? // posteo idempotente del motor automático (manual = null)
  status           JournalEntryStatus @default(POSTED)
  concept          String // descripción de la póliza
  totalDebitCents  Int // denormalizado = Σ líneas debe (== totalCreditCents por el invariante)
  totalCreditCents Int
  createdById      String? // staff que la creó (manual); null = motor
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  lines            JournalLine[]

  @@unique([organizationId, rfc, idempotencyKey]) // idempotencia (múltiples NULL permitidos en Postgres)
  @@unique([organizationId, rfc, folio]) // consecutivo ÚNICO por contribuyente (integridad fiscal; bloquea folios duplicados a nivel DB)
  @@index([organizationId, rfc, period])
  @@index([organizationId, rfc, date])
}

model JournalLine {
  id              String        @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)
  debitCents      Int           @default(0) // cargo (uno de los dos es > 0, el otro 0)
  creditCents     Int           @default(0) // abono
  description     String?
  createdAt       DateTime      @default(now())

  @@index([journalEntryId])
  @@index([ledgerAccountId])
}

/// Candado de periodo contable (Capa B fiscal). Un periodo CERRADO no admite pólizas nuevas ni
/// edición dentro de él (integridad de lo ya declarado). Scope = (organizationId, rfc). Reabrir deja
/// el row con status OPEN + bitácora (quién/cuándo), nunca se borra. Ref escalar a org (sin FK).
model AccountingPeriodLock {
  id             String                 @id @default(cuid())
  organizationId String // contribuyente = (organizationId, rfc)
  rfc            String
  period         String // YYYY-MM cerrado
  status         AccountingPeriodStatus @default(CLOSED)
  reason         String? // motivo del cierre / reapertura (bitácora)
  closedById     String? // staff que cerró el periodo
  closedAt       DateTime               @default(now())
  reopenedById   String? // staff que lo reabrió (si status = OPEN)
  reopenedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([organizationId, rfc, period]) // un candado por periodo por contribuyente
  @@index([organizationId, rfc, status])
}

enum JournalEntryType {
  INGRESO
  EGRESO
  DIARIO
}

enum JournalEntrySource {
  MANUAL
  PAYMENT
  REFUND
  CFDI
  COGS
  ADJUSTMENT
  OPENING
  EXPENSE
}

enum AccountingPeriodStatus {
  CLOSED
  OPEN
}

/// Gasto / CFDI recibido de proveedor (Buzón). Lado de ENTRADAS de Capa B: habilita IVA acreditable
/// (cash-basis), DIOT y costos/gastos reales. Scope = contribuyente (organizationId, rfc). FK escalares
/// (sin @relation): los registros fiscales NO se borran en cascada.
model Expense {
  id             String  @id @default(cuid())
  organizationId String
  rfc            String // receptor = nuestro contribuyente (UPPERCASE). (org, rfc) = scope.
  venueId        String? // informativo: centro de costo / quién lo subió

  // Proveedor (emisor) — snapshot denormalizado al ingestar
  proveedorRfc     String
  proveedorNombre  String
  proveedorRegimen String?
  tipoTercero      DiotTipoTercero @default(NACIONAL)

  // Clasificación
  comprobanteTipo ReceivedComprobanteTipo @default(INGRESO)
  usoCfdi         String?
  metodoPago      ExpenseMetodoPago       @default(PUE)
  formaPago       String?

  // Fechas
  fechaEmision DateTime
  fechaPago    DateTime?

  // Money (centavos enteros, MXN). Invariante: subtotal−descuento+iva+ieps−ivaRet−isrRet == total
  subtotalCents    Int
  descuentoCents   Int   @default(0)
  ivaCents         Int   @default(0)
  iva16Cents       Int   @default(0)
  iva8Cents        Int   @default(0)
  iva0BaseCents    Int   @default(0)
  exentoBaseCents  Int   @default(0)
  iepsCents        Int   @default(0)
  isrRetenidoCents Int   @default(0)
  ivaRetenidoCents Int   @default(0)
  totalCents       Int
  taxBreakdown     Json? // [{impuesto,tipoFactor,tasa,base,importe}] — SÍ se escribe (la DIOT-por-tasa depende)

  // Deducibilidad (criterio fiscal; default permisivo)
  deducible      Boolean @default(true)
  ivaAcreditable Boolean @default(true)

  // Contable
  expenseAccountCode String?
  ledgerAccountId    String?
  categoria          ExpenseCategoria @default(GASTO_GENERAL)
  journalEntryId     String?          @unique
  posted             Boolean          @default(false)

  // Pago (cash-basis): el IVA se acredita cuando se PAGA
  paymentStatus ExpensePaymentStatus @default(UNPAID)
  paidCents     Int                  @default(0)
  paidPeriod    String? // 'YYYY-MM' de fechaPago — campo que agregan IVA-flujo + DIOT

  // IDs fiscales / provenance
  uuid   String? // folio fiscal (nullable: extranjero/ticket)
  serie  String?
  folio  String?
  source ExpenseSource @default(MANUAL)
  xmlUrl String?
  pdfUrl String?

  supplierId String? // cross-link opcional al Supplier de inventario (no es la fuente de verdad fiscal)
  dedupeKey  String // = uuid si existe; si no, hash(proveedorRfc|fechaEmision|totalCents|folio)
  status     ExpenseStatus @default(REGISTERED)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([organizationId, rfc, uuid])
  @@unique([organizationId, rfc, dedupeKey])
  @@index([organizationId, rfc, paidPeriod])
  @@index([organizationId, rfc, proveedorRfc])
  @@index([organizationId, rfc, paymentStatus])
  @@index([venueId])
}

enum DiotTipoTercero {
  NACIONAL
  EXTRANJERO
  GLOBAL
}

enum ReceivedComprobanteTipo {
  INGRESO
  EGRESO
  NOMINA
  PAGO
  TRASLADO
}

enum ExpenseMetodoPago {
  PUE
  PPD
}

enum ExpensePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum ExpenseSource {
  MANUAL
  XML_UPLOAD
  SAT_DESCARGA
}

enum ExpenseStatus {
  REGISTERED
  CANCELLED
}

enum ExpenseCategoria {
  COSTO_MERCANCIA
  GASTO_GENERAL
  ARRENDAMIENTO
  COMBUSTIBLE
  HONORARIOS
  SERVICIOS
  OTRO
}

/// Empleado (nómina, Capa B). Scope = patrón (organizationId, rfc). FK escalares (sin @relation).
model Employee {
  id             String  @id @default(cuid())
  organizationId String
  rfc            String // RFC del PATRÓN (contribuyente). (org, rfc) = scope.
  venueId        String? // centro de costo (local donde trabaja)

  nombre      String
  rfcEmpleado String // RFC del trabajador
  curp        String?
  nss         String? // número de seguridad social
  puesto      String?

  /// Sueldo mensual bruto (percepción gravable base), en centavos.
  salarioMensualBrutoCents Int
  /// Salario base de cotización (SBC) mensual para IMSS, en centavos. Si null, se estima del bruto.
  sbcMensualCents          Int?
  periodicidadPago         PayrollPeriodicity @default(MENSUAL)

  // Datos fiscales para el CFDI de nómina (complemento Nómina 1.2).
  tipoContrato                String  @default("01") // c_TipoContrato (01 = indeterminado)
  tipoRegimen                 String  @default("02") // c_TipoRegimenContratacion (02 = sueldos y salarios)
  claveEntFed                 String? // c_Estado (CMX, JAL, NLE...) — requerido para timbrar
  numEmpleado                 String?
  registroPatronal            String? // registro patronal IMSS del patrón (opcional en el CFDI)
  /// Salario diario integrado (SDI) en centavos. Si null, se estima del SBC.
  salarioDiarioIntegradoCents Int?

  fechaIngreso DateTime?
  activo       Boolean   @default(true)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([organizationId, rfc, rfcEmpleado])
  @@index([organizationId, rfc])
  @@index([venueId])
}

/// Corrida de nómina de un periodo (Capa B). Scope = patrón (organizationId, rfc).
model PayrollRun {
  id             String  @id @default(cuid())
  organizationId String
  rfc            String
  venueId        String?

  period       String // 'YYYY-MM'
  periodicidad PayrollPeriodicity @default(MENSUAL)
  fechaPago    DateTime
  status       PayrollRunStatus   @default(DRAFT)

  empleados              Int @default(0)
  totalPercepcionesCents Int @default(0)
  totalIsrCents          Int @default(0)
  totalSubsidioCents     Int @default(0)
  totalImssObreroCents   Int @default(0)
  totalOtrasDeduccCents  Int @default(0)
  totalNetoCents         Int @default(0)

  journalEntryId String? @unique
  posted         Boolean @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([organizationId, rfc, period, periodicidad])
  @@index([organizationId, rfc, period])
}

/// Renglón por empleado de una corrida de nómina (snapshot del cálculo).
model PayrollLine {
  id           String @id @default(cuid())
  payrollRunId String
  employeeId   String

  nombre      String // snapshot
  rfcEmpleado String // snapshot

  diasPagados            Int @default(30)
  percepcionGravadaCents Int @default(0)
  percepcionExentaCents  Int @default(0)
  totalPercepcionesCents Int @default(0)
  isrCents               Int @default(0)
  subsidioCents          Int @default(0)
  imssObreroCents        Int @default(0)
  otrasDeduccionesCents  Int @default(0)
  netoCents              Int @default(0)

  // Recibo de nómina (CFDI 4.0 + complemento Nómina 1.2) timbrado para este empleado.
  cfdiStatus     PayrollCfdiStatus @default(PENDING)
  cfdiUuid       String? // folio fiscal del recibo timbrado
  cfdiProviderId String? // id del documento en el PAC (Facturapi)
  cfdiError      String? // último error de timbrado, si lo hubo

  createdAt DateTime @default(now())

  @@index([payrollRunId])
  @@index([employeeId])
}

enum PayrollPeriodicity {
  SEMANAL
  QUINCENAL
  MENSUAL
}

enum PayrollRunStatus {
  DRAFT
  POSTED
}

enum PayrollCfdiStatus {
  PENDING
  STAMPED
  ERROR
}

enum JournalEntryStatus {
  POSTED
  CANCELLED
}

// ==========================================
// CASH OUT SYSTEM (PlayTelecom promoter same-day commission withdrawal)
// Bespoke; gated by SERIALIZED_INVENTORY (appears wherever serialized inventory is on).
// Isolated by design: NO @relation into existing models (plain String ids +
// indexes; tenant isolation enforced in the service layer) so the scalable
// product's models stay untouched. Spec: Avoqado-HQ/specs/2026-06-25-cash-out-promoter-commissions.md
// ==========================================

enum PromoterSaleType {
  LINEA_NUEVA
  PORTABILIDAD
}

enum CashOutEntryStatus {
  AVAILABLE // Approved sale, withdrawable
  WITHDRAWN // Included in a withdrawal (Retirar)
  CLAWED_BACK // Source sale left COMPLETED after the fact (reconciliation)
}

enum CashOutWithdrawalStatus {
  REQUESTED // Promoter tapped Retirar (or back-office selected) — pending 18:15 corte
  REPORTED // Included in the 18:15 Finanzas SPEI dispersion report
  PAID // Finanzas confirmed the SPEI transfer
  FAILED // SPEI failed / reversed
}

/// Editable escalated commission table: FIXED peso amount per approved sale by
/// sale type and accumulated weekly sales count. Org- or venue-scoped. Backs the
/// Dashboard "Comisiones" editable table.
model CashOutCommissionRate {
  id       String           @id @default(cuid())
  orgId    String? // org-level config ...
  venueId  String? // ... or venue-level override
  saleType PromoterSaleType
  minCount Int // tier lower bound (accumulated sales this week), inclusive
  maxCount Int? // upper bound inclusive; null = open-ended top tier
  amount   Decimal          @db.Decimal(10, 2) // pesos per sale at this tier

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  active        Boolean   @default(true)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, saleType, active])
  @@index([venueId, saleType, active])
}

/// Which calendar days the cash-out scheme is active (ADMIN day-selection).
/// "Mutually exclusive with concurso" is enforced by the admin choosing days.
model CashOutScheduleDay {
  id          String   @id @default(cuid())
  orgId       String?
  venueId     String?
  day         DateTime @db.Date // a specific active day (venue-local)
  active      Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([venueId, day])
  @@index([orgId, day])
}

/// Promoter bank account (CLABE) for SPEI dispersion, captured by back-office.
/// Isolated from Staff (no change to the Staff model).
model PromoterBankAccount {
  id          String   @id @default(cuid())
  staffId     String   @unique // the promoter (plain ref; no FK by design)
  venueId     String?
  orgId       String?
  clabe       String // 18-digit CLABE
  holderName  String?
  active      Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([venueId])
  @@index([orgId])
}

/// Ledger: one entry per COMPLETED SaleVerification for a cash-out venue.
/// Amount/tier are LOCKED at materialization (count-so-far + 1). Status is
/// reconciled against the source sale's current status (clawback).
model PromoterCommissionEntry {
  id                 String             @id @default(cuid())
  saleVerificationId String             @unique // plain ref to SaleVerification (no FK by design)
  venueId            String
  staffId            String // the promoter
  saleType           PromoterSaleType
  businessDate       DateTime           @db.Date // venue-local day of the sale
  weekStart          DateTime           @db.Date // Monday of the Lun–Dom escalation week
  tier               Int // accumulated-count tier at materialization
  amount             Decimal            @db.Decimal(10, 2) // locked pesos
  status             CashOutEntryStatus @default(AVAILABLE)

  withdrawalId String?
  withdrawal   CashOutWithdrawal? @relation(fields: [withdrawalId], references: [id])

  clawedBackAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([venueId, staffId, status])
  @@index([venueId, businessDate])
  @@index([staffId, weekStart])
  @@index([withdrawalId])
}

/// A withdrawal (Retirar): sums AVAILABLE entries for a promoter, feeds the
/// 18:15 Finanzas SPEI dispersion report, then the comprobante.
model CashOutWithdrawal {
  id           String                  @id @default(cuid())
  venueId      String
  staffId      String // the promoter
  businessDate DateTime                @db.Date
  grossAmount  Decimal                 @db.Decimal(12, 2)
  feeMxn       Decimal                 @default(0) @db.Decimal(10, 2)
  netAmount    Decimal                 @db.Decimal(12, 2)
  clabe        String? // snapshot of the promoter's CLABE at request time
  folio        String                  @unique // human-facing receipt folio
  status       CashOutWithdrawalStatus @default(REQUESTED)

  requestedById String? // who triggered (promoter on TPV, or back-office)
  reportedAt    DateTime?
  paidAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries PromoterCommissionEntry[]

  @@index([venueId, businessDate, status])
  @@index([staffId])
  @@index([status])
}

// ==========================================
// PLATFORM BILLING CFDI (Avoqado factura a sus propios clientes)
// Avoqado-as-emisor: CFDIs que la PLATAFORMA timbra a SUS clientes (orgs, venues
// o receptores externos) por suscripción, setup, venta de TPV, etc. Distinto del
// motor tenant (FiscalEmisor/Cfdi) donde el venue factura a sus consumidores.
// Isolated by design (igual que CASH OUT): NO @relation a modelos existentes (ids
// String + índices; acceso forzado en la capa de servicio superadmin). Reusa el
// motor fiscal (src/services/fiscal/*: FacturapiProvider, fiscalKey, ivaMath) a
// nivel de servicio. Spec: docs/superpowers/specs/2026-06-26-platform-billing-cfdi-design.md
// ==========================================

enum PlatformCfdiStatus {
  DRAFT
  STAMPING
  STAMPED
  STAMP_FAILED
  CANCEL_REQUESTED
  CANCELLED
}

enum PlatformCfdiType {
  INGRESO // CFDI tipo I (la factura)
  PAGO // CFDI tipo P (complemento de pago / REP) — fase 2
}

enum BillingCustomerType {
  ORGANIZATION
  VENUE
  STANDALONE // receptor externo no dado de alta (ej. venta de TPV)
}

/// Avoqado como emisor (RFC + CSD + org de Facturapi). ≈ singleton (1 activo),
/// pero como tabla por si en el futuro hay >1 RFC emisor de plataforma.
model PlatformEmisor {
  id              String @id @default(cuid())
  rfc             String
  legalName       String
  regimenFiscal   String // c_RegimenFiscal (3 dígitos)
  lugarExpedicion String // fiscal CP

  provider         FiscalProviderType @default(FACTURAPI)
  providerOrgId    String? // facturapi org id
  providerKeyEnc   String? // encrypted live key (fiscalKey.service)
  csdStatus        CsdStatus          @default(NONE)
  csdExpiresAt     DateTime?
  csdLastCheckedAt DateTime?

  serie          String  @default("A")
  defaultUsoCfdi String?
  isActive       Boolean @default(true)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

/// Datos fiscales del receptor (cliente de Avoqado): org, venue o externo
/// (STANDALONE). Capturable a mano desde superadmin; constancia opcional.
model BillingTaxProfile {
  id             String              @id @default(cuid())
  customerType   BillingCustomerType
  organizationId String? // set si customerType=ORGANIZATION
  venueId        String? // set si customerType=VENUE (STANDALONE = ambos null)
  displayName    String? // etiqueta para STANDALONE

  rfc            String
  razonSocial    String
  regimenFiscal  String // c_RegimenFiscal
  codigoPostal   String // CP del receptor
  defaultUsoCfdi String  @default("G03")
  email          String?

  constanciaUrl    String? // PDF en Firebase Storage (opcional)
  validationStatus String    @default("PENDING") // PENDING | VALID | INVALID
  validatedAt      DateTime?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([organizationId])
  @@unique([venueId])
  @@index([rfc])
}

/// Un CFDI emitido por Avoqado a un cliente (ingreso; PAGO/REP en fase 2).
/// Espeja Cfdi pero a nivel plataforma. Money en centavos enteros (MXN).
model PlatformCfdi {
  id               String @id @default(cuid())
  platformEmisorId String

  billingTaxProfileId  String?
  type                 PlatformCfdiType @default(INGRESO)
  parentPlatformCfdiId String? // si type=PAGO: la factura de ingreso (PPD) que liquida

  // destinatario (denormalizado para listado/filtro); STANDALONE → ambos null
  organizationId String?
  venueId        String?

  // Receptor snapshot (inmutable al timbrar)
  receptorRfc     String
  receptorNombre  String
  receptorRegimen String
  receptorCp      String
  usoCfdi         String

  // Conceptos (JSON en MVP). Solo type=INGRESO.
  lines Json? // [{ description, satProductKey, satUnitKey, quantity, unitPriceCents, discountCents, taxRate, taxExempt }]

  // SAT payment classification
  formaPago  String // c_FormaPago
  metodoPago String @default("PUE") // PUE | PPD (solo INGRESO)

  // Money — integer cents
  subtotalCents Int    @default(0)
  discountCents Int    @default(0)
  taxCents      Int    @default(0)
  totalCents    Int    @default(0)
  currency      String @default("MXN")
  taxBreakdown  Json?

  // Seguimiento de pago PPD (derivado de los REP hijos) + detalle del REP
  amountPaidCents Int   @default(0)
  paymentInfo     Json? // solo type=PAGO

  status      PlatformCfdiStatus @default(DRAFT)
  facturapiId String?
  uuid        String?            @unique // folio fiscal (timbre)
  serie       String?
  folio       String?
  stampedAt   DateTime?

  xmlUrl String?
  pdfUrl String?

  lastError      String? @db.Text
  attempts       Int     @default(0)
  idempotencyKey String? @unique

  cancelMotivo         String?
  cancelSubstituteUuid String?
  cancelStatus         String?
  cancelledAt          DateTime?

  emailSentAt DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([venueId])
  @@index([status])
  @@index([type])
  @@index([parentPlatformCfdiId])
  @@index([createdAt])
}

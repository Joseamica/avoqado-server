// Organization-level attendance config defaults (inherited by venues without custom config)
// Venues with null attendance fields inherit from this; venues with explicit values override
model OrganizationAttendanceConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  expectedCheckInTime      String @default("09:00") // "HH:mm" — expected check-in time
  latenessThresholdMinutes Int    @default(30) // Minutes of tolerance after expectedCheckInTime
  geofenceRadiusMeters     Int    @default(500) // Max distance (meters) from venue for valid clock-in

  // Module defaults (inherited by venues without terminal-level overrides)
  attendanceTracking   Boolean @default(false)
  requireFacadePhoto   Boolean @default(false)
  requireDepositPhoto  Boolean @default(false)
  enableCashPayments   Boolean @default(true)
  enableCardPayments   Boolean @default(true)
  enableBarcodeScanner Boolean @default(true)

  // Full TPV terminal settings (all 35 fields as JSON)
  // Source of truth for org-level defaults. Individual columns above kept for backward compat.
  settings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Organization-level payout configuration defaults (inherited by venues)
model OrganizationPayoutConfig {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  aggregationPeriod String   @default("MONTHLY") // "WEEKLY" | "BIWEEKLY" | "MONTHLY" | "QUARTERLY"
  requireApproval   Boolean  @default(true)
  paymentMethods    String[] @default(["CASH", "BANK_TRANSFER"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// TPV APP UPDATE SYSTEM
// Dual update system: Blumon (provider) + Avoqado (self-managed)
// Allows independent control over app distribution
// ==========================================

enum AppEnvironment {
  SANDBOX // Development/testing builds
  PRODUCTION // Production builds for real terminals
}

/// Update notification mode for TPV app updates
enum UpdateMode {
  NONE // No notification - silent update available
  BANNER // Persistent banner - recommended update, user can dismiss/ignore
  FORCE // Blocking modal - critical update, app blocked until updated
}

/// Which app an AppUpdate row targets. Default keeps old TPV clients working
/// (they don't send platform and only ever see ANDROID_TPV rows).
enum AppPlatform {
  ANDROID_TPV // PAX terminal APK (legacy rows are all this)
  WINDOWS_DESKTOP // avoqado-desktop portable build
}

/// How an AppUpdate is targeted to terminals. Default ALL keeps old behavior
/// (every terminal in the environment gets it). VENUES scopes by the venue the
/// terminal reports (X-Venue-Id, always present once activated) — server-only,
/// no APK change. TERMINALS scopes by individual terminal serial; it stays inert
/// until the TPV app starts sending its serial on the update check (next APK).
enum AppUpdateTargetType {
  ALL // Todas las TPV (comportamiento por defecto)
  VENUES // Solo las TPV de los venues en targetVenueIds
  TERMINALS // Solo las terminales en targetTerminalIds (requiere APK que mande su serie)
}

/// Tracks TPV app versions uploaded by superadmin
/// Enables self-managed updates independent of Blumon
model AppUpdate {
  id String @id @default(cuid())

  // Version info (Android standard)
  versionName String // Semantic version: "1.3.0"
  versionCode Int // Android version code: 6 (always increments)

  // Environment + platform targeting
  environment AppEnvironment
  platform    AppPlatform    @default(ANDROID_TPV)

  // Audience targeting — which terminals this version rolls out to. Default ALL = every
  // terminal (today's behavior). VENUES uses targetVenueIds (resolved from X-Venue-Id, no
  // APK change). TERMINALS uses targetTerminalIds (inert until the APK sends its serial).
  targetType        AppUpdateTargetType @default(ALL)
  targetVenueIds    String[]            @default([]) // used when targetType = VENUES
  targetTerminalIds String[]            @default([]) // Terminal.id list, used when targetType = TERMINALS

  // Release info
  releaseNotes String?    @db.Text // Markdown changelog
  updateMode   UpdateMode @default(NONE) // NONE=silent, BANNER=recommended, FORCE=blocking

  // File info (Firebase Storage)
  downloadUrl String // Firebase Storage signed URL or public URL
  fileSize    BigInt // File size in bytes
  checksum    String // SHA-256 hash for integrity verification

  // Compatibility
  minAndroidSdk Int @default(27) // Minimum Android SDK (27 = Android 8.1)

  // Status
  isActive Boolean @default(true) // Whether this version is available for download

  // Audit
  uploadedById String
  uploadedBy   Staff  @relation("AppUpdateUploadedBy", fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Unique constraint: only one active version per environment
  // Allows multiple versions but queries filter by isActive
  @@unique([versionCode, environment])
  @@index([environment, isActive])
  @@index([versionCode])
}

// ==========================================
// VENUE CRYPTO CONFIG - Per-venue B4Bit device credentials
// ==========================================

enum CryptoConfigStatus {
  PENDING_SETUP // Device created, missing secretKey
  ACTIVE // Fully configured and validated
  INACTIVE // Manually disabled
}

model VenueCryptoConfig {
  id      String @id @default(cuid())
  venueId String @unique
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // B4Bit Device credentials
  b4bitDeviceId   String // API Key (UUID) - auto-created via POST /device/
  b4bitDeviceName String // Device name (= venue name for matching)
  b4bitSecretKey  String? // Device Secret Key (manual - from B4Bit dashboard)

  // Status
  status CryptoConfigStatus @default(PENDING_SETUP)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
}

// ==========================================
// MARKETING CAMPAIGNS - Superadmin mass email system
// ==========================================

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

/// Reusable email templates for marketing campaigns
model EmailTemplate {
  id       String @id @default(cuid())
  name     String
  subject  String
  bodyHtml String @db.Text
  bodyText String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  creator   Staff    @relation("EmailTemplateCreator", fields: [createdBy], references: [id])

  campaigns MarketingCampaign[]

  @@index([createdAt])
}

/// Marketing campaign for mass emails to venues/staff
model MarketingCampaign {
  id       String @id @default(cuid())
  name     String
  subject  String
  bodyHtml String @db.Text
  bodyText String @db.Text

  // Template reference (optional - if created from template)
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id])

  // Targeting
  targetAllVenues  Boolean  @default(true)
  targetVenueIds   String[] // Specific venue IDs if not targeting all
  includeStaff     Boolean  @default(false)
  targetStaffRoles String[] // OWNER, ADMIN, MANAGER, etc.

  // Status
  status       CampaignStatus @default(DRAFT)
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?

  // Stats (updated as emails are sent)
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  failedCount     Int @default(0)
  openedCount     Int @default(0) // Tracking: emails opened (via Resend webhooks)
  clickedCount    Int @default(0) // Tracking: links clicked (via Resend webhooks)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  creator   Staff    @relation("MarketingCampaignCreator", fields: [createdBy], references: [id])

  deliveries CampaignDelivery[]

  @@index([status])
  @@index([createdAt])
}

/// Individual email delivery within a campaign
model CampaignDelivery {
  id         String            @id @default(cuid())
  campaignId String
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  recipientEmail String
  recipientName  String?
  venueId        String?
  venueName      String?
  isStaff        Boolean @default(false)

  status   DeliveryStatus @default(PENDING)
  sentAt   DateTime?
  error    String?
  resendId String? // Resend email ID for tracking

  // Tracking (updated via Resend webhooks)
  openedAt     DateTime?
  clickedAt    DateTime?
  clickedLinks String[] // Track which links were clicked

  @@index([campaignId, status])
  @@index([recipientEmail])
  @@index([resendId])
}

// ==========================================
// TPV MESSAGING SYSTEM
// Dashboard → TPV terminal messaging (announcements, surveys, actions)
// ==========================================

/// Message sent from dashboard to TPV terminals
model TpvMessage {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Content
  type     TpvMessageType
  title    String
  body     String             @db.Text
  priority TpvMessagePriority @default(NORMAL)

  // Interaction config
  requiresAck Boolean @default(false) // Must acknowledge vs simple dismiss

  // Survey options (only for SURVEY type)
  surveyOptions     Json? // ["Option A", "Option B", "Option C"]
  surveyMultiSelect Boolean @default(false)

  // Action config (only for ACTION type)
  actionLabel   String? // Button text e.g. "Update menu"
  actionType    String? // What the TPV should do: REFRESH_MENU | SYNC_DATA | CUSTOM
  actionPayload Json? // Extra data for the action

  // Targeting
  targetType        TpvMessageTarget // ALL_TERMINALS | SPECIFIC_TERMINALS
  targetTerminalIds String[] // Terminal IDs (only when SPECIFIC_TERMINALS)

  // Scheduling & expiration
  scheduledFor DateTime? // Send at future time (null = immediate)
  expiresAt    DateTime? // Auto-dismiss after this time

  // Audit
  createdBy     String // Staff ID who created the message
  createdByName String // Staff name for display

  // Status
  status TpvMessageStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  deliveries TpvMessageDelivery[]
  responses  TpvMessageResponse[]

  @@index([venueId, status])
  @@index([status, scheduledFor])
  @@index([createdAt])
  @@map("tpv_messages")
}

/// Per-terminal delivery tracking for a TpvMessage
model TpvMessageDelivery {
  id         String     @id @default(cuid())
  messageId  String
  message    TpvMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  terminalId String
  terminal   Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  status         TpvMessageDeliveryStatus @default(PENDING)
  deliveredAt    DateTime?
  acknowledgedAt DateTime?
  dismissedAt    DateTime?
  acknowledgedBy String? // Staff PIN user who acknowledged

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([messageId, terminalId])
  @@index([terminalId, status])
  @@index([messageId, status])
  @@map("tpv_message_deliveries")
}

/// Survey response from a terminal for a TpvMessage
model TpvMessageResponse {
  id         String     @id @default(cuid())
  messageId  String
  message    TpvMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  terminalId String
  terminal   Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  selectedOptions String[] // Selected survey option texts
  respondedBy     String? // Staff ID
  respondedByName String? // Staff name

  createdAt DateTime @default(now())

  @@unique([messageId, terminalId])
  @@index([messageId])
  @@map("tpv_message_responses")
}

// ---- TPV Messaging Enums ----

enum TpvMessageType {
  ANNOUNCEMENT
  SURVEY
  ACTION
}

enum TpvMessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TpvMessageTarget {
  ALL_TERMINALS
  SPECIFIC_TERMINALS
}

enum TpvMessageStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TpvMessageDeliveryStatus {
  PENDING
  DELIVERED
  ACKNOWLEDGED
  DISMISSED
}

// ==========================================
// TRAINING / LMS SYSTEM
// ==========================================

model TrainingModule {
  id             String        @id @default(cuid())
  organizationId String? // null = global (available to all orgs)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title            String
  description      String             @db.Text
  coverImageUrl    String?
  category         TrainingCategory   @default(GENERAL)
  difficulty       TrainingDifficulty @default(BASIC)
  estimatedMinutes Int                @default(5)
  isRequired       Boolean            @default(false)
  position         Int                @default(0)
  status           TrainingStatus     @default(DRAFT)

  // Feature tags for auto-filtering (e.g., ["SERIALIZED_INVENTORY", "PAYMENTS"])
  // Empty = shown to ALL orgs. Non-empty = only shown if org has at least one matching module
  featureTags String[] @default([])

  // Venue-level filtering: if non-empty, only these venues see the training
  // Empty = all venues in the org (or all venues globally if organizationId is null)
  venueIds String[] @default([])

  quizPassThreshold Int @default(70) // Percentage needed to pass (1-100)
  quizMaxAttempts   Int @default(0) // 0 = unlimited

  createdBy     String
  createdByName String

  steps         TrainingStep[]
  quizQuestions TrainingQuizQuestion[]
  progress      TrainingProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("training_modules")
}

model TrainingStep {
  id               String         @id @default(cuid())
  trainingModuleId String
  trainingModule   TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Cascade)

  stepNumber   Int
  title        String
  instruction  String            @db.Text
  mediaType    TrainingMediaType @default(IMAGE)
  mediaUrl     String?
  thumbnailUrl String?
  tipText      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([trainingModuleId, stepNumber])
  @@map("training_steps")
}

model TrainingQuizQuestion {
  id               String         @id @default(cuid())
  trainingModuleId String
  trainingModule   TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Cascade)

  questionType   TrainingQuestionType @default(MULTIPLE_CHOICE)
  question       String
  options        String[]
  correctIndex   Int
  correctIndices Int[]                @default([]) // For MULTI_SELECT: multiple correct answers
  position       Int                  @default(0)
  explanation    String? // Explanation shown after quiz submission

  createdAt DateTime @default(now())

  @@map("training_quiz_questions")
}

model TrainingProgress {
  id               String         @id @default(cuid())
  trainingModuleId String
  trainingModule   TrainingModule @relation(fields: [trainingModuleId], references: [id], onDelete: Cascade)
  staffId          String
  venueId          String

  lastStepViewed Int      @default(0)
  isCompleted    Boolean  @default(false)
  quizScore      Int?
  quizTotal      Int?
  quizPassed     Boolean?
  attemptNumber  Int      @default(1)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@unique([trainingModuleId, staffId])
  @@map("training_progress")
}

enum TrainingCategory {
  VENTAS
  INVENTARIO
  PAGOS
  ATENCION_CLIENTE
  GENERAL
}

enum TrainingDifficulty {
  BASIC
  INTERMEDIATE
}

enum TrainingStatus {
  DRAFT
  PUBLISHED
}

enum TrainingMediaType {
  IMAGE
  VIDEO
}

enum TrainingQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  MULTI_SELECT
}

// ==========================================
// RESERVATION / BOOKING SYSTEM
// ==========================================

enum ReservationStatus {
  PENDING // Created, awaiting confirmation
  CONFIRMED // Confirmed (auto or manual)
  CHECKED_IN // Guest arrived
  COMPLETED // Service delivered
  CANCELLED // Cancelled by customer, staff, or system (expired)
  NO_SHOW // Guest didn't arrive within grace period
}

enum ReservationChannel {
  DASHBOARD // Created by staff
  WEB // Customer self-service (booking page/widget)
  PHONE // Phone booking logged by staff
  WHATSAPP // WhatsApp integration
  APP // Mobile app
  WALK_IN // Walk-in converted to reservation
  THIRD_PARTY // External sync (Google Reserve, etc.)
}

enum DepositStatus {
  PENDING // Deposit requested, not yet paid
  CARD_HOLD // Card captured via Stripe SetupIntent, not yet charged
  PAID // Payment received
  REFUNDED // Deposit returned to customer
  FORFEITED // Lost due to no-show/late cancel
  EXPIRED // Payment window closed
  DISPUTED // Chargeback/dispute in flight
}

enum RefundStatus {
  PENDING // Refund requested, Stripe call in flight or queued
  SUCCEEDED // Stripe acknowledged refund
  FAILED // Stripe refused or retries exhausted
}

enum WaitlistStatus {
  WAITING // In queue
  NOTIFIED // Slot opened, customer notified
  PROMOTED // Converted to reservation
  EXPIRED // No response within window
  CANCELLED // Left waitlist
}

model Reservation {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Human-readable confirmation code (e.g., "RES-A3X7K2") — for display/phone/WhatsApp
  confirmationCode String
  // Cryptographic token for public view/cancel (UUID v4 — NOT guessable like confirmationCode)
  cancelSecret     String @default(uuid())

  // Classification
  status  ReservationStatus  @default(PENDING)
  channel ReservationChannel @default(DASHBOARD)

  // Timing (all UTC — Prisma pattern)
  startsAt DateTime
  endsAt   DateTime
  duration Int // Minutes (denormalized for queries)

  // Guest info (linked Customer or anonymous)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestName  String?
  guestPhone String?
  guestEmail String?
  partySize  Int       @default(1)
  spotIds    String[]  @default([]) // Specific seat/spot IDs from product.layoutConfig

  // Direct resource references (NO junction tables for MVP)
  tableId         String?
  table           Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  // Multi-service appointments (Square pattern). When the customer books
  // multiple services in a single appointment we keep the lead service in
  // `productId` for back-compat with all existing queries/joins, and store
  // the full ordered list here. Order matters — services run sequentially.
  // Empty array = single-service (legacy) booking.
  productIds      String[]      @default([])
  classSessionId  String?
  classSession    ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  assignedStaffId String?
  assignedStaff   Staff?        @relation("ReservationStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  // Deposit (direct fields — avoids synthetic Orders that pollute KPIs)
  depositAmount       Decimal?       @db.Decimal(10, 2)
  depositStatus       DepositStatus?
  depositProcessorRef String? // Stripe PaymentIntent ID or processor reference
  depositPaidAt       DateTime?
  depositRefundedAt   DateTime?
  checkoutSessionId   String?
  depositExpiresAt    DateTime?
  idempotencyKey      String?        @unique

  // Stripe Connect routing — pinned at checkout-mint time so refunds and
  // reconciliation always go through the SAME connected account that
  // processed the original charge. Required by Stripe (refunds must
  // originate from the merchant that charged). Nullable for legacy rows
  // that predate this column + for bookings that never minted a charge
  // (pay-at-venue / credit redemption).
  ecommerceMerchantId String?
  ecommerceMerchant   EcommerceMerchant? @relation("ReservationEcommerceMerchant", fields: [ecommerceMerchantId], references: [id], onDelete: SetNull)

  // Refund lifecycle (orthogonal to depositStatus)
  refundStatus       RefundStatus?
  refundRequestedAt  DateTime?
  refundProcessorRef String?
  refundFailedReason String?
  refundRetryCount   Int           @default(0)

  // Staff assignment
  createdById String?
  createdBy   Staff?  @relation("ReservationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // Status timestamps (audit trail for MVP — proper ReservationHistory in Phase 2)
  confirmedAt DateTime?
  checkedInAt DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  noShowAt    DateTime?

  // Cancellation details
  cancelledBy        String? // Staff ID, "CUSTOMER", or "SYSTEM"
  cancellationReason String? @db.Text

  // Notes
  specialRequests String?  @db.Text
  internalNotes   String?  @db.Text
  tags            String[] @default([])

  // Simple JSON audit log for MVP (proper model in Phase 2)
  statusLog Json? // [{ status, at, by, reason? }]

  // Relations (Phase 2)
  waitlistPromotion ReservationWaitlistEntry?

  // Credit Packs — a single reservation can produce multiple transactions
  // (REDEEM at booking, REFUND on cancellation, etc.)
  creditTransactions CreditTransaction[]

  // No-show fee bookkeeping. Set by the auto-no-show worker when a venue
  // policy fee applies. `noShowFeeAmount` is the computed MXN amount (deposit
  // * noShowFeePercent / 100). `noShowFeeCapturedAt` is stamped if/when the
  // capture actually executes — for now the worker only records the intent
  // and leaves capture to the Stripe webhook path.
  noShowFeeAmount     Decimal?  @db.Decimal(10, 2)
  noShowFeeCapturedAt DateTime?

  // Idempotent log of reminder sends — one row per (reservation, offset, channel).
  reminderRecords ReservationReminderSent[]

  // Modifiers selected during booking for multi-service appointments
  modifiers ReservationModifier[]
  // Orders auto-created from this reservation on check-in.
  orders    Order[]               @relation("OrderFromReservation")

  // Google Calendar Sync (Phase 2 — push)
  calendarSyncOutbox  CalendarSyncOutbox[]
  googleEventMappings ReservationGoogleEventMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@unique([venueId, confirmationCode])
  @@index([venueId, status, startsAt])
  @@index([venueId, startsAt, endsAt])
  @@index([venueId, tableId, startsAt])
  @@index([venueId, productId, startsAt])
  @@index([venueId, classSessionId])
  @@index([venueId, assignedStaffId, startsAt])
  @@index([customerId])
  @@index([cancelSecret])
  @@index([depositStatus, depositExpiresAt])
  @@index([refundStatus, refundRequestedAt])
  @@index([ecommerceMerchantId])
}

// Idempotent reminder ledger. The reservation-reminder worker writes one row
// per (reservation, offsetMinutes, channel) BEFORE attempting the send so a
// retried tick or a parallel worker can't double-send. Unique constraint is
// the idempotency contract — never drop it.
model ReservationReminderSent {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  offsetMinutes Int // e.g. 1440 = 24h before start, 120 = 2h before start
  channel       String // 'EMAIL' | 'SMS' | 'WHATSAPP'

  sentAt       DateTime @default(now())
  success      Boolean
  errorMessage String?  @db.Text

  @@unique([reservationId, offsetMinutes, channel])
  @@index([reservationId])
  @@index([sentAt])
}

model ReservationModifier {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  // Which service in a multi-service appointment this modifier belongs to.
  // We don't FK to Product because Reservation.productIds is a text[] (Square pattern),
  // not a join table — keeping productId here as a tag matches that pattern.
  productId  String
  modifierId String?
  modifier   Modifier? @relation(fields: [modifierId], references: [id], onDelete: SetNull)

  // Denormalized — preserved if Modifier is deleted (parity with OrderItemModifier)
  name     String?
  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([reservationId])
  @@index([modifierId])
}

// Slot hold: temporarily reserves a time window while the customer fills out
// the public booking form. Square's "Cita reservada durante 9:56" pattern.
//
// Lifecycle:
//   1. Customer picks a slot → `POST /reservations/hold` creates a row with
//      expiresAt = NOW() + 10 min and returns its id to the widget.
//   2. Widget displays the countdown and stamps the id on its createReservation
//      call. The endpoint deletes the hold transactionally on success.
//   3. If the customer abandons the form, the row stays until lazy cleanup
//      sweeps it (any availability query past the hold's expiresAt skips it,
//      and a cheap `DELETE … WHERE expiresAt < now() - interval '1 hour'`
//      runs from the same getAvailability handler).
//
// Why a separate model and not a Reservation in HOLDING status: holds shouldn't
// pollute Reservation indexes / KPI dashboards / customer-facing "my bookings"
// queries, and we don't want hold cleanup to ever cascade-touch real
// reservations. Keeping them in their own table keeps the boundary clean.
model SlotHold {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Time window the customer is trying to book. Same shape as Reservation
  // so availability queries can union/exclude with a single overlap predicate.
  startsAt DateTime
  endsAt   DateTime

  // Multi-service appointments — same shape as Reservation.productIds. Empty
  // when the hold is for a single-service or class booking; the legacy
  // single-product reservation path stamps a one-element array here.
  productIds String[] @default([])

  // Class booking holds — when set, the hold competes against ClassSession
  // capacity, not table/staff availability.
  classSessionId String?
  classSession   ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  partySize Int @default(1)

  // TTL — past expiresAt the hold is dead and availability ignores it.
  expiresAt DateTime

  // Anti-abuse: hash of (ip + user-agent). Lets us cap concurrent holds per
  // fingerprint per venue without forcing customers to log in.
  fingerprint String?

  createdAt DateTime @default(now())

  // Hot path: getAvailability filters by venueId + expiresAt > now() and
  // overlap-tests against startsAt/endsAt for every queried slot.
  @@index([venueId, startsAt, endsAt])
  @@index([venueId, expiresAt])
  @@index([expiresAt]) // for the lazy cleanup sweep
  @@index([venueId, classSessionId])
}

enum ClassSessionStatus {
  SCHEDULED // Open for bookings
  CANCELLED // Cancelled — no new bookings allowed
  COMPLETED // Session already happened
}

model ClassSession {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Schedule
  startsAt DateTime
  endsAt   DateTime
  duration Int // Minutes (denormalized for queries)

  // Capacity — overrides product.maxParticipants for this session
  capacity Int

  // Staff
  assignedStaffId String?
  assignedStaff   Staff?  @relation("ClassSessionStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  status ClassSessionStatus @default(SCHEDULED)

  // Internal notes
  internalNotes String? @db.Text

  // Relations
  reservations Reservation[]
  slotHolds    SlotHold[]

  // Google Calendar Sync (Phase 2 — push)
  calendarSyncOutbox  CalendarSyncOutbox[]
  googleEventMappings ReservationGoogleEventMapping[]

  createdById String?
  createdBy   Staff?  @relation("ClassSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, startsAt])
  @@index([venueId, productId, startsAt])
  @@index([venueId, status, startsAt])
}

model ReservationWaitlistEntry {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestName  String?
  guestPhone String?

  partySize      Int            @default(1)
  desiredStartAt DateTime
  desiredEndAt   DateTime?
  status         WaitlistStatus @default(WAITING)
  position       Int // Queue position (party-size-aware, not pure FIFO)

  notifiedAt       DateTime?
  responseDeadline DateTime?

  // If converted to reservation
  promotedReservationId String?      @unique
  promotedReservation   Reservation? @relation(fields: [promotedReservationId], references: [id], onDelete: SetNull)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, status, desiredStartAt])
  @@index([venueId, status, partySize])
}

model ReservationSettings {
  id      String @id @default(cuid())
  venueId String @unique
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Scheduling
  slotIntervalMin    Int     @default(15)
  defaultDurationMin Int     @default(60)
  autoConfirm        Boolean @default(true)
  maxAdvanceDays     Int     @default(60)
  minNoticeMin       Int     @default(60)
  noShowGraceMin     Int     @default(15)

  // Pacing
  pacingMaxPerSlot      Int? // null = no pacing limit
  onlineCapacityPercent Int  @default(100)

  // Deposits (legacy venue-wide control — kept for backwards compatibility)
  depositMode          String   @default("none") // none | card_hold | deposit | prepaid
  depositFixedAmount   Decimal? @db.Decimal(10, 2)
  depositPercentage    Int? // percentage of service price
  depositPartySizeGte  Int? // require deposit for parties >= this size
  depositPaymentWindow Int? // minutes to complete payment

  // Type-aware payment defaults (Phase 3 of public booking redesign).
  //
  // Override depositMode per product TYPE — Square's pattern where classes
  // default to pay-now and appointments default to pay-at-venue. A product
  // with upfrontPolicy='inherit' (the default) resolves against these.
  // A product whose upfrontPolicy is set explicitly always wins.
  //
  // Values: 'required' | 'at_venue' | 'optional'
  appointmentUpfrontDefault String @default("at_venue")
  classUpfrontDefault       String @default("required")

  // Waitlist
  waitlistEnabled      Boolean @default(true)
  waitlistMaxSize      Int     @default(50)
  waitlistPriorityMode String  @default("fifo") // fifo | party_size | broadcast
  waitlistNotifyWindow Int     @default(30) // minutes

  // Public booking
  publicBookingEnabled Boolean @default(false)
  requirePhone         Boolean @default(true)
  requireEmail         Boolean @default(false)
  requireAccount       Boolean @default(false) // when true, customer must log in or register before booking

  // Cancellation
  allowCustomerCancel         Boolean @default(true)
  minHoursBeforeCancel        Int?    @default(2) // minimum hours before start to allow cancellation
  forfeitDeposit              Boolean @default(false)
  noShowFeePercent            Int? // percentage of deposit/service charged on no-show
  // Reschedule: customers can swap to a different slot of the SAME class up to N hours
  // before the start. We default to mirror the cancel window (industry-standard pattern
  // — reschedule is essentially atomic cancel+rebook).
  allowCustomerReschedule     Boolean @default(true)
  // Credit pack refund policy on cancellation:
  //   "NEVER"      - never refund credits (customer always loses them)
  //   "ALWAYS"     - always refund 100% regardless of timing
  //   "TIME_BASED" - refund 100% if cancelled >= creditFreeRefundHoursBefore, else creditLateRefundPercent
  creditRefundMode            String  @default("TIME_BASED") // NEVER | ALWAYS | TIME_BASED
  creditFreeRefundHoursBefore Int     @default(12)
  creditLateRefundPercent     Int     @default(0) // 0-100, applied when cancelled inside the late window
  creditNoShowRefund          Boolean @default(false) // refund credits if marked NO_SHOW

  // Reminders
  remindersEnabled  Boolean  @default(true)
  reminderChannels  String[] @default(["EMAIL"])
  reminderMinBefore Int[]    @default([1440, 120]) // minutes before reservation

  // Operating hours (per-day weekly schedule, venue local time)
  operatingHours Json? // null = use defaults (Mon-Sat 09:00-22:00, Sunday closed)

  // Google Calendar Sync (Phase 2 — push direction).
  // Push toggle is independent of module enablement so a venue can pause push
  // without disconnecting the calendar (read-side / pull stays active).
  googleCalendarPushEnabled              Boolean @default(true)
  // Dual-write fans the push out to BOTH the staff personal calendar AND the
  // venue master. Default is single-target (staff if assigned, else venue).
  googleCalendarDualWrite                Boolean @default(false)
  // Detail level controls what fields appear in the Google event body.
  // FULL = customer name, service, party size visible (locked-in default per
  // user decision 2026-05-16). Other values: 'SERVICE' | 'MINIMAL'.
  googleCalendarEventDetailLevel         String  @default("FULL")
  // When true, cancellations hard-delete the Google event; when false (default)
  // we patch the event to status='cancelled' for an audit trail.
  googleCalendarRemoveCancelled          Boolean @default(false)
  // For ClassSession push: include the attendee roster in the event description.
  googleCalendarClassRosterInDescription Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// GOOGLE CALENDAR SYNC (Phase 1)
// Two-scope model: VENUE (one master per venue) and STAFF_PERSONAL (one per staff).
// Read-only sync in Phase 1: Google events become ExternalBusyBlock rows that block
// availability in `book.avoqado.io` and the dashboard reservation calendar.
// ==========================================

enum GoogleCalendarConnectionScope {
  VENUE
  STAFF_PERSONAL
}

enum GoogleCalendarConnectionStatus {
  CONNECTED
  TOKEN_REVOKED
  CALENDAR_LOST
  WATCH_FAILED
  DISCONNECTED
}

enum GoogleCalendarChannelStatus {
  ACTIVE
  RENEWING
  EXPIRED
  STOPPED
}

/// One Google Calendar connection for a venue or a staff member.
/// Backed at the DB level by a CHECK constraint that enforces exactly one of
/// (venueId, staffId) is set, matching the `scope` discriminator.
/// Refresh / access tokens are AES-256-GCM encrypted with GOOGLE_CALENDAR_TOKEN_KEY.
model GoogleCalendarConnection {
  id      String                        @id @default(cuid())
  scope   GoogleCalendarConnectionScope
  venueId String?
  venue   Venue?                        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  staffId String?
  staff   Staff?                        @relation("StaffGoogleCalendarConnection", fields: [staffId], references: [id], onDelete: Cascade)

  googleAccountEmail       String
  googleAccountSub         String
  selectedCalendarId       String
  selectedCalendarSummary  String
  selectedCalendarTimeZone String

  refreshTokenCiphertext Bytes
  accessTokenCiphertext  Bytes?
  accessTokenExpiresAt   DateTime?

  // Incremental sync state (set after Phase A backfill completes)
  syncToken      String?
  lastSyncedAt   DateTime?
  lastHorizonEnd DateTime? // Furthest future timestamp covered by backfill

  status         GoogleCalendarConnectionStatus @default(CONNECTED)
  statusReason   String?                        @db.Text
  connectedAt    DateTime                       @default(now())
  disconnectedAt DateTime?

  createdByStaffId String?
  createdByStaff   Staff?  @relation("StaffCreatedGoogleConnection", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  channels   GoogleCalendarChannel[]
  busyBlocks ExternalBusyBlock[]

  // Google Calendar Sync (Phase 2 — push)
  outboxRows    CalendarSyncOutbox[]
  eventMappings ReservationGoogleEventMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
  @@index([staffId])
  @@index([status])
}

/// A Google Calendar push-notification channel ("events.watch" subscription).
/// Channels expire after ~7 days and are renewed via the gcal-channel-renewal cron.
model GoogleCalendarChannel {
  id           String                   @id @default(cuid())
  connectionId String
  connection   GoogleCalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  channelId  String                      @unique // Google channel id (UUID we generate)
  resourceId String // Google calendar resource id
  token      String // Random secret echoed in webhook headers for verification
  expiresAt  DateTime
  status     GoogleCalendarChannelStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  stoppedAt DateTime?

  @@index([connectionId, status])
  @@index([expiresAt, status])
  @@index([resourceId])
}

/// External-source busy-time block. Phase 1 covers Google Calendar events as
/// opaque blocks (we never reveal event titles to public-facing surfaces).
/// `venueId` is denormalized for fast availability queries; `staffId` is set
/// when the connection is STAFF_PERSONAL.
model ExternalBusyBlock {
  id                 String                   @id @default(cuid())
  googleConnectionId String
  connection         GoogleCalendarConnection @relation(fields: [googleConnectionId], references: [id], onDelete: Cascade)
  venueId            String?
  staffId            String?

  externalSource     String @default("GOOGLE")
  externalCalendarId String
  externalEventId    String

  startsAt DateTime
  endsAt   DateTime
  allDay   Boolean  @default(false)

  title     String? @db.Text
  isPrivate Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([googleConnectionId, externalEventId])
  @@index([venueId, startsAt, endsAt])
  @@index([staffId, startsAt, endsAt])
}

/// Durable inbox for Google Calendar webhook notifications. We write a row here
/// BEFORE acking the webhook so a downstream worker can deliver-at-least-once
/// even if RabbitMQ is momentarily unavailable. The inbox sweeper cron picks
/// orphan rows (`processedAt IS NULL` AND old `receivedAt`).
model GoogleCalendarWebhookInbox {
  id            String @id @default(cuid())
  connectionId  String
  channelId     String
  resourceId    String
  resourceState String
  messageNumber String

  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  attempts    Int       @default(0)
  lastError   String?   @db.Text

  @@index([processedAt, receivedAt])
  @@index([connectionId, processedAt])
}

/// Short-lived (10 minute) one-shot bridge row used to hand the OAuth tokens
/// produced by the redirect callback to the authenticated dashboard session that
/// completes the calendar-selection step. The session token is delivered to the
/// dashboard via a signed cookie; only the SHA-256 hash is stored here.
/// `consumedAt` is set atomically on use to prevent replay.
model GoogleOAuthSession {
  id        String @id @default(cuid())
  tokenHash String @unique

  authUserId String
  intent     String // 'staff_personal' | 'venue_master'
  venueId    String?
  staffId    String?

  encryptedRefreshToken Bytes
  encryptedAccessToken  Bytes
  accessTokenExpiresAt  DateTime

  googleAccountEmail String
  googleAccountSub   String

  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([expiresAt])
}

// ==========================================
// GOOGLE CALENDAR SYNC (Phase 2 — push direction)
// Avoqado reservations / class sessions → Google Calendar events.
// Outbox-pattern guarantees: writes happen inside the same SERIALIZABLE
// transaction as the source row, so we never push without a committed
// reservation and never lose a push if RabbitMQ blips.
// ==========================================

/// Operation enqueued for push. UPDATE_ROSTER is ClassSession-only — a
/// debounced description-only patch that re-renders the attendee list.
enum CalendarSyncOperation {
  CREATE
  UPDATE
  CANCEL
  UPDATE_ROSTER
}

/// Outbox lifecycle. SKIPPED is set by the CANCEL pre-flight collapse logic
/// (an earlier CREATE/UPDATE for the same syncKey was superseded). DEAD_LETTER
/// is terminal after `attempts` exhausts the retry budget.
enum CalendarSyncStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  DEAD_LETTER
  SKIPPED
}

/// Durable push-intent rows. We insert one row PER (source-row × target-connection)
/// inside the same DB transaction as the source mutation. A consumer + sweeper
/// drain rows with single-flight semantics keyed on `syncKey` (pg advisory lock).
model CalendarSyncOutbox {
  id String @id @default(cuid())

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  classSessionId String?
  classSession   ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  operation CalendarSyncOperation

  targetConnectionId String
  targetConnection   GoogleCalendarConnection @relation(fields: [targetConnectionId], references: [id], onDelete: Cascade)

  // Logical ordering key — "reservation:<id>:<connId>" or "class:<id>:<connId>".
  // The push worker takes a pg_try_advisory_xact_lock on hashtext(syncKey)
  // to serialize operations against the same target.
  syncKey String

  // De-dupes "exact same intent re-enqueued" at the DB layer. Caller derives
  // this from (syncKey, operation, sourceUpdatedAt) so a retry of the SAME
  // mutation collapses to one row.
  idempotencyKey String @unique

  status   CalendarSyncStatus @default(PENDING)
  attempts Int                @default(0)

  scheduledAt DateTime  @default(now())
  processedAt DateTime?
  lastError   String?   @db.Text

  // ClassSession UPDATE_ROSTER debounce window — sweeper / worker skips rows
  // until NOW() >= debounceUntil, then collapses pending UPDATE_ROSTER rows
  // for the same syncKey into one.
  debounceUntil DateTime?

  createdAt DateTime @default(now())

  @@index([status, scheduledAt])
  @@index([venueId, status])
  @@index([syncKey, status, createdAt]) // collapse query
  @@index([reservationId])
  @@index([classSessionId])
  @@index([targetConnectionId])
}

/// Mapping between an Avoqado source row (reservation OR class session) and the
/// Google Calendar event id created for it on a specific connection. PK is
/// (connectionId, googleEventId) because googleEventId is only unique within a
/// single calendar. Partial unique indexes on (reservationId, connectionId) and
/// (classSessionId, connectionId) enforce "one event per source per target"
/// while allowing the column to be NULL when the other side is set.
/// Exactly-one-of (reservationId, classSessionId) MUST be set — enforced at the
/// DB layer by a CHECK constraint added in the migration SQL.
model ReservationGoogleEventMapping {
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  classSessionId String?
  classSession   ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)

  connectionId String
  connection   GoogleCalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  googleEventId String

  lastPushedAt DateTime
  // "PUSHED" | "PATCHED" | "TOMBSTONED" | "FAILED"
  lastStatus   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([connectionId, googleEventId])
  @@index([reservationId])
  @@index([classSessionId])
}

// ==========================================
// PAYMENT LINK SETTINGS — per-venue defaults + notifications
// ==========================================
//
// Backs the "Ajustes generales" page under "Ligas de Pago" in the dashboard.
// Per-link config (tippingConfig, customFields) still lives on PaymentLink
// for cases where a venue overrides defaults at creation time. This table
// stores the venue-wide defaults the dashboard pre-fills the form with, plus
// notification preferences and the public merchant policies text.
model VenuePaymentLinkSettings {
  id      String @id @default(cuid())
  venueId String @unique
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Notifications — fire emails to venue admin (OWNER/ADMIN role staff) when
  // a payment link is paid. TODO: split into per-source toggles once we add
  // PaymentLink.source (DASHBOARD/TPV/EMBED/API). Currently any paid link
  // triggers the email if this flag is on.
  notifyOnPaid Boolean @default(false)

  // Defaults applied to NEW payment links when the creator doesn't override.
  // Shape mirrors PaymentLink fields: { presets: number[], allowCustom: boolean }
  // for tipping, and CustomFieldDefinition[] for custom fields.
  defaultTippingConfig Json?
  defaultCustomFields  Json?

  // Quick toggle: when ON and no defaultCustomFields are set, the create
  // dialog seeds a single optional TEXT field labeled "Nota" so customers
  // can leave a comment. Lets admin enable the UX without configuring a
  // full custom fields array.
  customerNotesEnabled Boolean @default(false)

  // Merchant policies — markdown text shown on the public payment page.
  // Customer-facing legal disclaimers (refund policy, terms, etc.).
  merchantPolicies String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// NOTE: CREDIT PACKS / BUNDLES SYSTEM
// ==========================================

model CreditPack {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  price       Decimal @db.Decimal(10, 2)
  currency    String  @default("MXN")

  validityDays   Int? // Days from purchase until expiration (null = no expiration)
  maxPerCustomer Int? // Max purchases per customer (null = unlimited)
  active         Boolean @default(true)
  displayOrder   Int     @default(0)

  // Stripe (one-time product/price)
  stripeProductId String?
  stripePriceId   String?

  // Relations
  items     CreditPackItem[]
  purchases CreditPackPurchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, active])
}

model CreditPackItem {
  id           String     @id @default(cuid())
  creditPackId String
  creditPack   CreditPack @relation(fields: [creditPackId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int // Number of credits for this product (e.g., 10 classes)

  // Relations
  balances CreditItemBalance[]

  @@unique([creditPackId, productId])
  @@index([creditPackId])
}

model CreditPackPurchase {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  creditPackId String
  creditPack   CreditPack @relation(fields: [creditPackId], references: [id])

  purchasedAt DateTime             @default(now())
  expiresAt   DateTime?
  status      CreditPurchaseStatus @default(ACTIVE)

  // Stripe
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?
  amountPaid              Decimal @db.Decimal(10, 2)

  // Relations
  itemBalances CreditItemBalance[]
  transactions CreditTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId, customerId, status])
  @@index([customerId])
  @@index([expiresAt])
}

enum CreditPurchaseStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  REFUNDED
}

model CreditItemBalance {
  id                   String             @id @default(cuid())
  creditPackPurchaseId String
  creditPackPurchase   CreditPackPurchase @relation(fields: [creditPackPurchaseId], references: [id], onDelete: Cascade)

  creditPackItemId String
  creditPackItem   CreditPackItem @relation(fields: [creditPackItemId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  originalQuantity  Int // Quantity at purchase time
  remainingQuantity Int // Current balance

  // Relations
  transactions CreditTransaction[]

  @@unique([creditPackPurchaseId, creditPackItemId])
  @@index([creditPackPurchaseId])
  @@index([productId])
}

model CreditTransaction {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  customerId           String
  customer             Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  creditPackPurchaseId String
  creditPackPurchase   CreditPackPurchase @relation(fields: [creditPackPurchaseId], references: [id])
  creditItemBalanceId  String
  creditItemBalance    CreditItemBalance  @relation(fields: [creditItemBalanceId], references: [id])

  type     CreditTransactionType
  quantity Int // +N for PURCHASE, -1 for REDEEM, etc.

  // Context: what triggered this transaction.
  // Not unique — a single reservation can have a REDEEM and a later REFUND linked to it.
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  orderId       String?
  order         Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)

  reason      String?     @db.Text
  createdById String?
  createdBy   StaffVenue? @relation("CreditTransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([creditItemBalanceId, createdAt])
  @@index([customerId, createdAt])
  @@index([reservationId])
  @@index([orderId])
}

enum CreditTransactionType {
  PURCHASE
  REDEEM
  EXPIRE
  REFUND
  ADJUST
}

// ==========================================
// PAYMENT LINKS
// ==========================================

model PaymentLink {
  id        String @id @default(cuid())
  shortCode String @unique // 8-char alphanumeric (nanoid)

  venueId             String
  venue               Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  ecommerceMerchantId String
  ecommerceMerchant   EcommerceMerchant @relation(fields: [ecommerceMerchantId], references: [id], onDelete: Restrict)
  createdById         String
  createdBy           Staff             @relation("PaymentLinkCreatedBy", fields: [createdById], references: [id])

  /// Staff explicitly chosen by the link creator to receive commission
  /// attribution when the link is paid. Separate from `createdById`:
  /// the link CREATOR may be an admin/manager who shouldn't earn the
  /// commission. With 0 attributions → no commission. With N → commission
  /// is split equally across all attributed staff (see finalizePaymentLink
  /// Checkout + createSplitCommissionForPayment).
  attributions PaymentLinkAttribution[]

  purpose PaymentLinkPurpose @default(PAYMENT)

  /// Line items (only used for ITEM purpose). Bundle-style: customer pays
  /// the fixed total of `sum(quantity × product.price)`. Deleted products
  /// cascade out via PaymentLinkItem onDelete: Cascade.
  items PaymentLinkItem[]

  title       String
  description String?
  imageUrl    String?

  amountType PaymentLinkAmountType // FIXED | OPEN
  amount     Decimal?              @db.Decimal(12, 2)
  currency   String                @default("MXN")

  isReusable  Boolean   @default(false)
  expiresAt   DateTime?
  redirectUrl String?

  // Custom fields config: [{ id, type: "TEXT"|"SELECT", label, required, options? }]
  customFields  Json?
  // Tipping config: { presets: [10, 15, 20], allowCustom: true } — null = disabled
  tippingConfig Json?

  status         PaymentLinkStatus @default(ACTIVE)
  totalCollected Decimal           @default(0) @db.Decimal(12, 2)
  paymentCount   Int               @default(0)

  checkoutSessions CheckoutSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venueId])
  @@index([shortCode])
  @@index([status])
  @@index([createdAt])
}

/// Line item for an ITEM-purpose PaymentLink (bundle). Fixed quantity per
/// product set at link creation. Stripe-style line_items pattern. Total =
/// sum(quantity × (product.price + sum(modifier.price))) at checkout. The
/// customer cannot edit the quantity or modifiers — for cart-style flows
/// we'd need a separate model.
model PaymentLinkItem {
  id            String      @id @default(cuid())
  paymentLinkId String
  paymentLink   PaymentLink @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity      Int         @default(1)
  /// Stable ordering for UI / preview / receipt — admin can drag-reorder
  /// without changing the underlying rows.
  position      Int         @default(0)
  createdAt     DateTime    @default(now())

  /// Pre-selected modifiers for this line. Admin picks them at link-creation
  /// time. The customer cannot change them — the bundle is fixed. At payment
  /// completion these are replayed into OrderItemModifier rows so cocina,
  /// inventory deduction, and reports see the full configuration.
  modifiers PaymentLinkItemModifier[]

  @@unique([paymentLinkId, productId])
  @@index([productId])
}

/// Pre-selected modifier for a bundle line item. Joins PaymentLinkItem ↔
/// Modifier with a quantity (e.g. "2× extra cheese"). Validation in the
/// service layer ensures: (a) the modifier belongs to one of the product's
/// modifier groups, (b) required groups have at least one selection,
/// (c) max-selection bounds per group are respected.
model PaymentLinkItemModifier {
  id                String          @id @default(cuid())
  paymentLinkItemId String
  paymentLinkItem   PaymentLinkItem @relation(fields: [paymentLinkItemId], references: [id], onDelete: Cascade)
  modifierId        String
  modifier          Modifier        @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  quantity          Int             @default(1)
  createdAt         DateTime        @default(now())

  @@unique([paymentLinkItemId, modifierId])
  @@index([modifierId])
}

/// Many-to-many between PaymentLink and Staff. Each row = one staff member
/// who shares commission for sales via this link. With N rows, commission
/// is split equally (1/N). With 0 rows, no commission is calculated. The
/// FIRST row also acts as `Payment.processedById` so reports/receipts have
/// a single named staff to display.
model PaymentLinkAttribution {
  id            String      @id @default(cuid())
  paymentLinkId String
  paymentLink   PaymentLink @relation(fields: [paymentLinkId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([paymentLinkId, staffId])
  @@index([staffId])
}

enum PaymentLinkPurpose {
  PAYMENT // Accept a payment (generic)
  ITEM // Sell an item (linked to Product, creates Order + deducts inventory)
  DONATION // Accept a donation (open amount)
}

enum PaymentLinkAmountType {
  FIXED
  OPEN
}

enum PaymentLinkStatus {
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

// ==========================================
// CASH DRAWER
// ==========================================

model CashDrawerSession {
  id              String            @id @default(cuid())
  venueId         String
  venue           Venue             @relation(fields: [venueId], references: [id])
  deviceName      String?
  openedByStaffId String
  openedByName    String
  openedAt        DateTime          @default(now())
  startingAmount  Decimal           @db.Decimal(12, 2)
  closedByStaffId String?
  closedByName    String?
  closedAt        DateTime?
  actualAmount    Decimal?          @db.Decimal(12, 2)
  overShort       Decimal?          @db.Decimal(12, 2)
  closingNote     String?
  status          CashDrawerStatus  @default(OPEN)
  events          CashDrawerEvent[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([venueId])
  @@index([status])
}

model CashDrawerEvent {
  id        String              @id @default(cuid())
  sessionId String
  session   CashDrawerSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

}

// ==========================================
// MEASUREMENT UNITS (Custom units per venue)
// ==========================================

model MeasurementUnit {
  id           String   @id @default(cuid())
  venueId      String
  venue        Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name         String // e.g., "Kilogramo", "Litro", "Pieza"
  abbreviation String // e.g., "kg", "L", "pz"
  createdAt    DateTime @default(now())

  @@index([venueId])
}

// ==========================================
// AGGREGATOR / PAYMENT INTERMEDIARY SYSTEM
// ==========================================

model Aggregator {
  id          String  @id @default(cuid())
  name        String  @unique
  venueId     String?
  baseFees    Json // {DEBIT: 0.025, CREDIT: 0.025, AMEX: 0.033, INTERNATIONAL: 0.033}
  ivaRate     Decimal @default(0.16) @db.Decimal(5, 4) // 0.16 = 16% IVA Mexico
  reportToken String? @unique // Secret token for public report access
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchants        MerchantAccount[]
  venueCommissions VenueCommission[]

  @@index([active])
}

model VenueCommission {
  id           String  @id @default(cuid())
  venueId      String  @unique
  aggregatorId String
  rate         Decimal @db.Decimal(5, 4) // 0.0462 = 4.62%
  referredBy   String // "EXTERNAL" or "AGGREGATOR"
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue      Venue      @relation(fields: [venueId], references: [id])
  aggregator Aggregator @relation(fields: [aggregatorId], references: [id])

  @@index([aggregatorId])
  @@index([active])
}

